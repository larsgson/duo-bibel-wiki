---
import { ClientRouter } from "astro:transitions";
import langsData from "../data/ALL-langs-compact.json";

interface LangEntry {
    code: string;
    name: string;
    vernacular: string;
}

interface Props {
    title: string;
    learnCode?: string;
    learnName?: string;
    mtCode?: string;
    mtName?: string;
    flexMode?: boolean;
    noHeader?: boolean;
    backHref?: string;
    themeCSS?: string;
}

const {
    title,
    learnCode,
    learnName,
    mtCode,
    mtName,
    flexMode,
    noHeader,
    backHref,
    themeCSS,
} = Astro.props;

// Compute language lists for selector modals
const hasSelectorModal = !noHeader && !!learnCode;
let computedLearnLangs: LangEntry[] = [];
let computedMtLangs: LangEntry[] = [];
let computedLearnUrlTemplate = mtCode ? `/{code}/${mtCode}` : "/{code}";
let computedMtUrlTemplate = learnCode ? `/${learnCode}/{code}` : "/{code}";

if (hasSelectorModal) {
    const wt = langsData.canons.nt["with-timecode"] as Record<string, { n?: string; v?: string }>;
    const awt = langsData.canons.nt["audio-with-timecode"] as Record<string, { n?: string; v?: string }>;
    const seenP = new Set<string>();
    for (const src of [wt, awt]) {
        for (const [code, info] of Object.entries(src)) {
            if (!seenP.has(code)) {
                seenP.add(code);
                computedLearnLangs.push({ code, name: info.n || code, vernacular: info.v || "" });
            }
        }
    }
    computedLearnLangs.sort((a, b) => a.name.localeCompare(b.name));

    const seenS = new Set<string>();
    for (const canon of ["nt", "ot"] as const) {
        const canonData = (langsData.canons as any)[canon];
        if (!canonData) continue;
        for (const cat of Object.keys(canonData)) {
            const catData = canonData[cat] as Record<string, { n?: string; v?: string }>;
            for (const [code, info] of Object.entries(catData)) {
                if (!seenS.has(code)) {
                    seenS.add(code);
                    computedMtLangs.push({ code, name: info.n || code, vernacular: info.v || "" });
                }
            }
        }
    }
    computedMtLangs.sort((a, b) => a.name.localeCompare(b.name));
}
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="light dark" />
        <title>{title}</title>
        <ClientRouter />
        <style>
            @layer theme-defaults {
                :root {
                    /* Page */
                    --bg: #ffffff;
                    --bg-surface: rgba(0, 0, 0, 0.04);
                    --bg-surface-hover: rgba(0, 0, 0, 0.08);
                    --bg-panel: #f5f5f5;
                    /* Text */
                    --text: #1a1a2e;
                    --text-secondary: #555;
                    --text-muted: #888;
                    --text-on-accent: #fff;
                    /* Accent */
                    --accent: #5b9bd5;
                    --accent-hover: #4a8bc4;
                    --accent-light: rgba(91, 155, 213, 0.12);
                    --header-bg: #007bff;
                    /* Borders */
                    --border: rgba(0, 0, 0, 0.1);
                    --border-strong: rgba(0, 0, 0, 0.2);
                    /* Overlays & shadows */
                    --overlay: rgba(0, 0, 0, 0.5);
                    --shadow: rgba(0, 0, 0, 0.15);
                    --shadow-strong: rgba(0, 0, 0, 0.3);
                    /* Feedback */
                    --success: #5cb85c;
                    --success-bright: #22cc00;
                    --error: #d9534f;
                    --error-text: #1a1a1a;
                    /* Controls */
                    --input-bg: #fff;
                    --input-border: rgba(0, 0, 0, 0.2);
                    --fab-bg: #f0f0f0;
                    --chevron: #999;
                }
            }
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                font-family:
                    system-ui,
                    -apple-system,
                    sans-serif;
                min-height: 100vh;
                min-height: 100dvh;
                display: flex;
                flex-direction: column;
                background: var(--bg);
                color: var(--text);
            }
            body.flex-mode {
                height: 100vh;
                height: 100dvh;
                min-height: 0;
                overflow: hidden;
            }
            body.flex-mode .main-content {
                display: flex;
                flex-direction: column;
                overflow: hidden;
            }
            /* Header */
            .app-header {
                background: var(--header-bg);
                color: var(--text-on-accent);
                box-shadow: 0 2px 8px var(--shadow-strong);
            }
            .header-content {
                max-width: 1200px;
                margin: 0 auto;
                padding: 1rem 1.5rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .header-left {
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }
            .back-button {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 36px;
                height: 36px;
                border-radius: 6px;
                background: rgba(255, 255, 255, 0.15);
                color: var(--text-on-accent);
                text-decoration: none;
                transition: background 0.2s;
                flex-shrink: 0;
            }
            .back-button:hover {
                background: var(--text-muted);
            }
            .back-button svg {
                width: 20px;
                height: 20px;
            }
            .app-title {
                font-size: 1.5rem;
                font-weight: 600;
            }
            .app-title a {
                color: var(--text-on-accent);
                text-decoration: none;
            }
            .language-button {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.5rem 1rem;
                background: var(--border);
                border: 1px solid var(--border-strong);
                border-radius: 6px;
                color: var(--text-on-accent);
                font-size: 1rem;
                cursor: pointer;
                transition: all 0.2s;
                text-decoration: none;
                min-height: 44px;
            }
            .language-button:hover {
                background: rgba(255, 255, 255, 0.18);
            }
            .language-icon-wrapper {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 0.15rem;
                flex-shrink: 0;
            }
            .language-icon {
                font-size: 1.1rem;
                line-height: 1;
            }
            .language-code-label {
                font-size: 0.55rem;
                font-family: monospace;
                font-weight: 600;
                text-transform: uppercase;
                line-height: 1;
                opacity: 0.8;
            }
            .language-text {
                font-weight: 500;
                line-height: 1.4;
            }

            /* Header compact language buttons */
            .header-langs {
                display: flex;
                gap: 0.5rem;
                align-items: center;
            }
            .learn-lang-wrapper {
                position: relative;
            }
            .lang-dropdown-arrow {
                font-size: 0.7rem;
                opacity: 0.6;
                margin-left: -2px;
            }
            .learn-lang-dropdown {
                display: none;
                position: absolute;
                top: 100%;
                right: 0;
                margin-top: 4px;
                background: var(--bg);
                border: 1px solid var(--border);
                border-radius: 8px;
                box-shadow: 0 8px 24px var(--shadow-strong);
                min-width: 200px;
                z-index: 1100;
                overflow: hidden;
            }
            .learn-lang-dropdown.open {
                display: block;
            }
            .learn-lang-dropdown a,
            .learn-lang-dropdown button {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                width: 100%;
                padding: 0.6rem 0.85rem;
                border: none;
                background: none;
                color: var(--text);
                text-decoration: none;
                font: inherit;
                font-size: 0.85rem;
                cursor: pointer;
                transition: background 0.15s;
                text-align: left;
            }
            .learn-lang-dropdown a:hover,
            .learn-lang-dropdown button:hover {
                background: var(--bg-surface-hover);
            }
            .learn-lang-dropdown .lang-dd-code {
                font-family: monospace;
                font-size: 0.75rem;
                color: var(--text-muted);
                min-width: 2.5em;
            }
            .learn-lang-dropdown .lang-dd-active {
                font-weight: 700;
            }
            .learn-lang-dropdown .lang-dd-check {
                color: var(--accent);
                font-size: 0.8rem;
                margin-left: auto;
            }
            .learn-lang-dropdown .lang-dd-divider {
                height: 1px;
                background: var(--border);
                margin: 0;
            }
            .learn-lang-dropdown .lang-dd-more {
                color: var(--accent);
                font-size: 0.8rem;
                padding: 0.5rem 0.85rem;
            }
            .language-button.compact {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.4rem 0.6rem;
                min-height: 36px;
            }
            .language-button.compact .language-code-label {
                font-size: 0.65rem;
            }
            .lang-pair-arrow {
                font-size: 1.1rem;
                opacity: 0.7;
                flex-shrink: 0;
            }
            .lang-pair-name {
                font-weight: 500;
                white-space: nowrap;
            }
            @media (max-width: 768px) {
                .lang-pair-name {
                    display: none;
                }
            }

            /* Main content */
            .main-content {
                flex: 1;
                width: 100%;
            }

            @media (max-width: 768px) {
                .header-content {
                    padding: 0.75rem 1rem;
                }
                .app-title {
                    font-size: 1.25rem;
                }
                .language-button {
                    padding: 0.4rem 0.5rem;
                    font-size: 0.875rem;
                    gap: 0.5rem;
                }
                .language-text {
                    display: none;
                }
            }
        </style>
        <style is:global>
            /* ── Dim active verse card during focus mode ── */
            body.focus-mode .listen-verse-card.active {
                opacity: 0.15 !important;
                pointer-events: none !important;
                border-color: transparent !important;
                background: transparent !important;
            }
            /* Enlarge active verse text to match focus panel size */
            body.focus-mode .listen-verse-card.active .listen-verse-text-learn {
                font-size: calc(1.05rem * var(--learn-font-scale, 1));
                line-height: 1.6;
            }
            body.focus-mode .listen-verse-card.active .listen-verse-text-mt {
                font-size: calc(0.95rem * var(--mt-font-scale, 1));
                line-height: 1.6;
            }

            /* ── Mini player (layout-level, persists across navigations) ── */
            .listen-player {
                position: fixed;
                bottom: 72px;
                right: 16px;
                width: 280px;
                height: 160px;
                border: 2px solid #0f3460;
                border-radius: 12px;
                box-shadow: 0 8px 24px var(--shadow-strong);
                cursor: pointer;
                transition: all 0.3s ease;
                z-index: 1001;
                overflow: hidden;
            }
            .listen-player:hover {
                transform: scale(1.02);
                box-shadow: 0 12px 32px var(--shadow-strong);
                border-color: #1a4d7a;
            }
            @media (min-width: 769px) {
                .listen-player { bottom: 16px; }
            }
            @media (max-width: 640px) {
                .listen-player { width: 240px; height: 140px; bottom: 68px; right: 12px; }
            }
            @media (max-width: 400px) {
                .listen-player { width: 200px; height: 120px; bottom: 64px; right: 8px; }
            }
            .listen-player-image {
                position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
            }
            .listen-player-image img {
                width: 100%; height: 100%; object-fit: cover; display: block;
            }
            .listen-player-overlay {
                position: absolute; top: 0; left: 0; right: 0; bottom: 0;
                display: flex; flex-direction: column; justify-content: flex-end;
                background: radial-gradient(circle, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.1) 70%, transparent 100%);
                z-index: 2;
            }
            .listen-player-content {
                display: flex; align-items: flex-end; justify-content: space-between;
                padding: 12px 16px; gap: 12px;
            }
            @media (max-width: 640px) {
                .listen-player-content { padding: 10px 12px; gap: 10px; }
            }
            @media (max-width: 400px) {
                .listen-player-content { padding: 8px 10px; }
            }
            .listen-player-info { flex: 1; min-width: 0; }
            .listen-player-title {
                color: #eee; font-size: 11px; font-weight: 500; letter-spacing: 0.3px;
                white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
                text-shadow: 0 1px 3px rgba(0,0,0,0.8);
            }
            @media (max-width: 640px) { .listen-player-title { font-size: 10px; } }
            @media (max-width: 400px) { .listen-player-title { font-size: 9px; } }
            .listen-player-lang {
                color: rgba(255,255,255,0.6); font-size: 9px;
                text-shadow: 0 1px 3px rgba(0,0,0,0.8); margin-top: 2px;
            }
            .listen-player-btn {
                background: rgba(15,52,96,0.85); border: none; border-radius: 4px;
                color: var(--text-on-accent); width: 24px; height: 24px; min-width: 24px; min-height: 24px;
                display: flex; align-items: center; justify-content: center;
                cursor: pointer; transition: all 0.3s ease;
                box-shadow: 0 4px 16px var(--shadow-strong); flex-shrink: 0;
                padding: 2px; outline: none;
            }
            .listen-player-btn svg { width: 20px; height: 20px; flex-shrink: 0; }
            .listen-player-btn:hover { background: rgba(26,77,122,0.95); transform: scale(1.1); }
            .listen-player-btn:active { transform: scale(0.95); }
            .mini-player-close { position: absolute; top: 4px; right: 4px; z-index: 3; }
            @media (max-width: 640px) {
                .listen-player-btn { width: 22px; height: 22px; min-width: 22px; min-height: 22px; }
                .listen-player-btn svg { width: 18px; height: 18px; }
            }
            @media (max-width: 400px) {
                .listen-player-btn { width: 20px; height: 20px; min-width: 20px; min-height: 20px; }
                .listen-player-btn svg { width: 16px; height: 16px; }
            }
            .listen-player-pulse {
                position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
                background: linear-gradient(90deg, #e94560 0%, #ff6b7a 100%);
                animation: listen-pulse 2s ease-in-out infinite; z-index: 3;
            }
            @keyframes listen-pulse {
                0%, 100% { opacity: 0.5; transform: scaleX(0.8); }
                50% { opacity: 1; transform: scaleX(1); }
            }

            /* ── Focus mode panel ── */
            .focus-panel-backdrop {
                position: fixed; inset: 0;
                background: var(--overlay);
                z-index: 900;
            }
            .focus-panel {
                position: fixed; top: 50%; left: 50%;
                transform: translate(-50%, -50%);
                z-index: 950;
                width: min(90vw, 600px);
                border: 3px solid var(--error);
                border-radius: 0.75rem;
                background: var(--bg);
                box-shadow: 0 16px 48px var(--shadow-strong);
                overflow: hidden;
            }
            @media (max-width: 480px) {
                .focus-panel { width: 95vw; }
            }
            .focus-panel-content { position: relative; }
            .focus-panel-content img {
                width: 100%; display: block; overflow: hidden;
            }
            .focus-panel-content img:first-child {
                border-radius: 0.5rem 0.5rem 0 0;
            }
            /* Focus panel reuses .listen-verse-* classes, enlarged */
            .focus-panel-content .listen-verse-text-learn {
                font-size: calc(1.05rem * var(--learn-font-scale, 1));
                line-height: 1.6;
            }
            .focus-panel-content .listen-verse-text-mt {
                font-size: calc(0.95rem * var(--mt-font-scale, 1));
                line-height: 1.6;
            }
            .focus-panel-controls {
                position: absolute; top: 50%; left: 50%;
                transform: translate(-50%, -50%);
                display: flex; gap: 16px; align-items: center;
                z-index: 10; pointer-events: auto;
            }
            .focus-panel-btn {
                background: var(--text-muted); border: none; border-radius: 50%;
                width: 64px; height: 64px;
                display: flex; align-items: center; justify-content: center;
                cursor: pointer; color: var(--text-on-accent); transition: background 0.15s;
            }
            .focus-panel-btn:hover { background: rgba(255,255,255,0.4); }
            .focus-panel-stop { width: 52px; height: 52px; }
            @media (max-width: 480px) {
                .focus-panel-btn { width: 52px; height: 52px; }
                .focus-panel-stop { width: 44px; height: 44px; }
            }

            /* Ken Burns animation variants */
            @keyframes kenBurns1 { 0% { transform: scale(1) translate(0,0); } 100% { transform: scale(1.15) translate(-3%,-2%); } }
            @keyframes kenBurns2 { 0% { transform: scale(1) translate(0,0); } 100% { transform: scale(1.12) translate(2%,-3%); } }
            @keyframes kenBurns3 { 0% { transform: scale(1) translate(0,0); } 100% { transform: scale(1.18) translate(-2%,2%); } }
            @keyframes kenBurns4 { 0% { transform: scale(1) translate(0,0); } 100% { transform: scale(1.14) translate(3%,1%); } }
            .focus-panel-content img.ken-burns-1 { animation: kenBurns1 linear forwards; }
            .focus-panel-content img.ken-burns-2 { animation: kenBurns2 linear forwards; }
            .focus-panel-content img.ken-burns-3 { animation: kenBurns3 linear forwards; }
            .focus-panel-content img.ken-burns-4 { animation: kenBurns4 linear forwards; }
            body.audio-paused .focus-panel-content img { animation-play-state: paused; }
        </style>
        {themeCSS && <style set:html={themeCSS} />}
    </head>
    <body class={flexMode ? "flex-mode" : undefined}>
        {!noHeader && (
            <header class="app-header">
                <div class="header-content">
                    <div class="header-left">
                        {
                            backHref && (
                                <a
                                    class="back-button"
                                    href={backHref}
                                    aria-label="Back"
                                >
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <polyline points="15 18 9 12 15 6" />
                                    </svg>
                                </a>
                            )
                        }
                        <h1 class="app-title"><a href="/">Duo Bibel Wiki</a></h1>
                    </div>
                    {
                        learnCode ? (
                            <div class="header-langs">
                                <div class="learn-lang-wrapper">
                                    <button
                                        class="language-button compact"
                                        data-lang-selector="learn"
                                        id="learn-lang-btn"
                                    >
                                        <div class="language-icon-wrapper">
                                            <span class="language-icon">🌐</span>
                                            <span class="language-code-label">
                                                {learnCode}
                                            </span>
                                        </div>
                                        <span class="lang-pair-name">{learnName}</span>
                                        <span class="lang-dropdown-arrow">&#x25BE;</span>
                                    </button>
                                    <div class="learn-lang-dropdown" id="learn-lang-dropdown"></div>
                                </div>
                                <button
                                    class="language-button compact"
                                    data-lang-selector="mt"
                                >
                                    <span class="lang-pair-arrow">&larr;</span>
                                    <div class="language-icon-wrapper">
                                        <span class="language-icon">🌐</span>
                                        <span class="language-code-label" id="header-lang2-label">
                                            {mtCode || "\u2014"}
                                        </span>
                                    </div>
                                    <span class="lang-pair-name">{mtName || ""}</span>
                                </button>
                            </div>
                        ) : (
                            <a class="language-button" href="/">
                                <span class="language-icon">🌐</span>
                                <span class="language-text">Select language</span>
                            </a>
                        )
                    }
                </div>
            </header>
        )}
        <main class="main-content">
            <slot />
        </main>
        {
            hasSelectorModal && (
                <>
                    <style>
                        .lang-modal-overlay {
                            display: none;
                            position: fixed;
                            inset: 0;
                            background: var(--overlay);
                            z-index: 1000;
                            align-items: flex-start;
                            justify-content: center;
                            padding: 2rem 1rem;
                            overflow-y: auto;
                        }
                        .lang-modal-overlay.open {
                            display: flex;
                        }
                        .lang-modal {
                            background: var(--bg);
                            border-radius: 12px;
                            border: 1px solid var(--border);
                            width: 100%;
                            max-width: 900px;
                            max-height: calc(100vh - 4rem);
                            max-height: calc(100dvh - 4rem);
                            display: flex;
                            flex-direction: column;
                            box-shadow: 0 8px 32px var(--shadow-strong);
                        }
                        .lang-modal-header {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            padding: 1rem 1.5rem;
                            border-bottom: 1px solid var(--border);
                            flex-shrink: 0;
                        }
                        .lang-modal-header h2 {
                            font-size: 1.25rem;
                        }
                        .lang-modal-close {
                            background: none;
                            border: none;
                            color: var(--text-muted);
                            font-size: 1.5rem;
                            cursor: pointer;
                            padding: 0.25rem 0.5rem;
                            border-radius: 4px;
                            line-height: 1;
                        }
                        .lang-modal-close:hover {
                            color: var(--text);
                            background: var(--border);
                        }
                        .lang-modal-body {
                            padding: 1rem 1.5rem;
                            overflow-y: auto;
                            flex: 1;
                        }
                        .lang-modal-search {
                            width: 100%;
                            max-width: 500px;
                            margin: 0 auto 1rem;
                            display: block;
                            padding: 0.75rem 1rem;
                            font-size: 1.1rem;
                            border: 2px solid var(--border);
                            border-radius: 8px;
                            outline: none;
                            background: var(--bg-surface-hover);
                            color: var(--text);
                            box-sizing: border-box;
                        }
                        .lang-modal-search::placeholder {
                            color: var(--text-muted);
                        }
                        .lang-modal-search:focus {
                            border-color: #6ea8fe;
                        }
                        .lang-modal-count {
                            text-align: center;
                            color: var(--text-muted);
                            margin: 0.5rem 0 1.25rem;
                            font-size: 0.95rem;
                        }
                        .lang-modal-grid {
                            display: grid;
                            grid-template-columns: repeat(
                                auto-fill,
                                minmax(260px, 1fr)
                            );
                            gap: 0.5rem;
                        }
                        .lang-modal-item {
                            display: flex;
                            align-items: baseline;
                            gap: 0.5rem;
                            padding: 0.6rem 0.85rem;
                            background: var(--bg-surface);
                            border-radius: 6px;
                            text-decoration: none;
                            color: var(--text);
                            border: 1px solid var(--bg-surface-hover);
                            cursor: pointer;
                        }
                        .lang-modal-item:hover {
                            background: var(--bg-surface-hover);
                            border-color: rgba(110, 168, 254, 0.3);
                        }
                        .lang-modal-item .lm-code {
                            color: var(--text-muted);
                            font-size: 0.8rem;
                            font-family: monospace;
                            flex-shrink: 0;
                        }
                        .lang-modal-item .lm-name {
                            font-weight: 500;
                        }
                        .lang-modal-item .lm-vern {
                            color: #6ea8fe;
                            font-size: 0.85rem;
                        }
                        .lang-modal-item .lm-highlight {
                            background: rgba(110, 168, 254, 0.25);
                            color: #6ea8fe;
                            border-radius: 2px;
                        }
                        .lang-modal-no-results {
                            text-align: center;
                            color: var(--text-muted);
                            padding: 3rem 1rem;
                            font-size: 1.1rem;
                        }
                        @media (max-width: 768px) {
                            .lang-modal-overlay {
                                padding: 1rem 0.5rem;
                            }
                            .lang-modal-body {
                                padding: 1rem;
                            }
                            .lang-modal-grid {
                                grid-template-columns: 1fr;
                            }
                        }
                    </style>
                    <div class="lang-modal-overlay" id="lang-modal-overlay">
                        <div class="lang-modal">
                            <div class="lang-modal-header">
                                <h2 id="lang-modal-title">Select language</h2>
                                <button
                                    class="lang-modal-close"
                                    id="lang-modal-close"
                                >
                                    &times;
                                </button>
                            </div>
                            <div class="lang-modal-body">
                                <input
                                    class="lang-modal-search"
                                    id="lang-modal-search"
                                    type="text"
                                    placeholder="Search by name, vernacular, or code..."
                                />
                                <p
                                    class="lang-modal-count"
                                    id="lang-modal-count"
                                />
                                <div
                                    class="lang-modal-grid"
                                    id="lang-modal-grid"
                                />
                                <p
                                    class="lang-modal-no-results"
                                    id="lang-modal-no-results"
                                    style="display:none"
                                >
                                    No languages found
                                </p>
                            </div>
                        </div>
                    </div>
                    <script
                        define:vars={{
                            learnLangs: computedLearnLangs,
                            mtLangs: computedMtLangs,
                            learnUrlTemplate: computedLearnUrlTemplate,
                            mtUrlTemplate: computedMtUrlTemplate,
                            _langCode: learnCode,
                            _lang2Code: mtCode,
                        }}
                    >
                        const overlay = document.getElementById(
                            "lang-modal-overlay",
                        );
                        const titleEl =
                            document.getElementById("lang-modal-title");
                        const closeBtn =
                            document.getElementById("lang-modal-close");
                        const searchInput =
                            document.getElementById("lang-modal-search");
                        const countEl =
                            document.getElementById("lang-modal-count");
                        const grid =
                            document.getElementById("lang-modal-grid");
                        const noResults = document.getElementById(
                            "lang-modal-no-results",
                        );

                        let currentLangs = [];
                        let currentTemplate = "";

                        function openLangModal(type) {
                            if (type === "learn") {
                                currentLangs = learnLangs;
                                currentTemplate = learnUrlTemplate;
                                titleEl.textContent =
                                    "Select language to learn";
                            } else {
                                currentLangs = mtLangs;
                                currentTemplate = mtUrlTemplate;
                                titleEl.textContent =
                                    "Select mother tongue";
                            }
                            searchInput.value = "";
                            renderGrid("");
                            overlay.classList.add("open");
                            searchInput.focus();
                        }

                        function closeLangModal() {
                            overlay.classList.remove("open");
                        }

                        const RTL_RE = /[\u0590-\u05FF\u0600-\u06FF\u0700-\u074F\u0750-\u077F\u0780-\u07BF\u07C0-\u07FF\u08A0-\u08FF\uFB1D-\uFDFF\uFE70-\uFEFF]/;

                        function escapeRegex(s) {
                            return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
                        }

                        function hl(text, regex) {
                            if (!regex) return text;
                            return text.replace(
                                regex,
                                (m) =>
                                    `<span class="lm-highlight">${m}</span>`,
                            );
                        }

                        function renderGrid(term) {
                            const lc = term.toLowerCase();
                            const regex = lc
                                ? new RegExp(
                                      `(${escapeRegex(lc)})`,
                                      "gi",
                                  )
                                : null;
                            let visible = 0;
                            let html = "";

                            for (const lang of currentLangs) {
                                if (
                                    lc &&
                                    !lang.code
                                        .toLowerCase()
                                        .includes(lc) &&
                                    !lang.name
                                        .toLowerCase()
                                        .includes(lc) &&
                                    !(lang.vernacular || "")
                                        .toLowerCase()
                                        .includes(lc)
                                ) {
                                    continue;
                                }
                                visible++;
                                const url = currentTemplate.replace(
                                    "{code}",
                                    lang.code,
                                );
                                const vernRtl = lang.vernacular && RTL_RE.test(lang.vernacular) ? ' dir="rtl"' : "";
                                const vern = lang.vernacular
                                    ? `<span class="lm-vern"${vernRtl}> - ${hl(lang.vernacular, regex)}</span>`
                                    : "";
                                html += `<a class="lang-modal-item" href="${url}"><span class="lm-code">${hl(lang.code, regex)}</span><span class="lm-name">${hl(lang.name, regex)}</span>${vern}</a>`;
                            }

                            grid.innerHTML = html;
                            countEl.textContent = lc
                                ? `${visible} of ${currentLangs.length} languages`
                                : `${currentLangs.length} languages`;
                            noResults.style.display =
                                visible === 0 ? "" : "none";
                            grid.style.display =
                                visible === 0 ? "none" : "";
                        }

                        // ── Recent learn languages dropdown ──
                        const RECENT_KEY = "recentLearnLangs";
                        const MAX_RECENT = 7;
                        const learnBtn = document.getElementById("learn-lang-btn");
                        const dropdown = document.getElementById("learn-lang-dropdown");

                        function getRecentLearnLangs() {
                            try { return JSON.parse(localStorage.getItem(RECENT_KEY) || "[]"); }
                            catch (e) { return []; }
                        }

                        function addRecentLearnLang(code) {
                            const recent = getRecentLearnLangs().filter(r => r.code !== code);
                            const info = learnLangs.find(l => l.code === code);
                            if (info) {
                                recent.unshift({ code: info.code, name: info.name, vernacular: info.vernacular || "" });
                            } else {
                                recent.unshift({ code, name: code, vernacular: "" });
                            }
                            try { localStorage.setItem(RECENT_KEY, JSON.stringify(recent.slice(0, MAX_RECENT))); }
                            catch (e) {}
                        }

                        // Record current learn language
                        if (_langCode) addRecentLearnLang(_langCode);

                        function buildLearnLangUrl(newLearnCode) {
                            const parts = window.location.pathname.split("/");
                            // URL: /lang/lang2/...  →  parts[1] = lang
                            if (parts.length >= 2 && parts[1]) {
                                parts[1] = newLearnCode;
                                return parts.join("/");
                            }
                            return "/" + newLearnCode + "/";
                        }

                        function closeDropdown() {
                            dropdown.classList.remove("open");
                        }

                        function openDropdown() {
                            const recent = getRecentLearnLangs();
                            if (recent.length <= 1) {
                                openLangModal("learn");
                                return;
                            }
                            let html = "";
                            for (const lang of recent) {
                                const isActive = lang.code === _langCode;
                                const url = buildLearnLangUrl(lang.code);
                                html += `<a href="${url}" class="${isActive ? "lang-dd-active" : ""}">`;
                                html += `<span class="lang-dd-code">${lang.code}</span>`;
                                html += `<span>${lang.name}</span>`;
                                if (isActive) html += `<span class="lang-dd-check">&#x2713;</span>`;
                                html += `</a>`;
                            }
                            html += `<div class="lang-dd-divider"></div>`;
                            html += `<button class="lang-dd-more" id="lang-dd-more-btn">More languages\u2026</button>`;
                            dropdown.innerHTML = html;
                            dropdown.classList.add("open");

                            dropdown.querySelector("#lang-dd-more-btn")?.addEventListener("click", () => {
                                closeDropdown();
                                openLangModal("learn");
                            });
                        }

                        // Button handlers
                        document
                            .querySelectorAll("[data-lang-selector]")
                            .forEach((btn) => {
                                btn.addEventListener("click", () => {
                                    const type = btn.dataset.langSelector;
                                    if (type === "learn") {
                                        if (dropdown.classList.contains("open")) {
                                            closeDropdown();
                                        } else {
                                            openDropdown();
                                        }
                                    } else {
                                        openLangModal(type);
                                    }
                                });
                            });

                        // Close dropdown on outside click
                        document.addEventListener("click", (e) => {
                            if (!e.target.closest(".learn-lang-wrapper")) {
                                closeDropdown();
                            }
                        });

                        closeBtn.addEventListener("click", closeLangModal);
                        overlay.addEventListener("click", (e) => {
                            if (e.target === overlay) closeLangModal();
                        });
                        document.addEventListener("keydown", (e) => {
                            if (
                                e.key === "Escape" &&
                                overlay.classList.contains("open")
                            )
                                closeLangModal();
                        });
                        searchInput.addEventListener("input", () => {
                            renderGrid(searchInput.value.trim());
                        });

                        // If no lang2Code from server, update label from localStorage
                        if (!_lang2Code) {
                            try {
                                var ls = JSON.parse(localStorage.getItem("lastState") || "{}");
                                if (ls.lang === _langCode && ls.lang2) {
                                    var lbl = document.getElementById("header-lang2-label");
                                    if (lbl) lbl.textContent = ls.lang2;
                                }
                            } catch (e) {}
                        }
                    </script>
                </>
            )
        }
        <!-- Mini player (persists across page transitions) -->
        <div id="mini-player-root" transition:persist="audio-player" style="display:none;">
            <div class="listen-player" id="mini-player">
                <div class="listen-player-image" id="mini-player-image"></div>
                <button class="listen-player-btn mini-player-close" id="mini-player-close" aria-label="Stop" style="display:none">
                    <svg width="22" height="22" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:block"><path d="M18 6L6 18M6 6l12 12" stroke="#fff" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
                </button>
                <div class="listen-player-overlay">
                    <div class="listen-player-content">
                        <div class="listen-player-info">
                            <div class="listen-player-title" id="mini-player-title">&mdash;</div>
                        </div>
                        <button class="listen-player-btn" id="mini-player-btn" aria-label="Play">
                            <svg id="mini-player-icon-play" width="22" height="22" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:block"><path d="M8 5v14l11-7z" fill="#fff"/></svg>
                            <svg id="mini-player-icon-pause" width="22" height="22" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:none"><rect x="6" y="4" width="4" height="16" fill="#fff"/><rect x="14" y="4" width="4" height="16" fill="#fff"/></svg>
                        </button>
                    </div>
                </div>
                <div class="listen-player-pulse" id="mini-player-pulse" style="display:none;"></div>
            </div>
        </div>

        <!-- Focus mode panel (persists across page transitions) -->
        <div id="focus-root" transition:persist="focus-panel">
            <div class="focus-panel-backdrop" id="focus-backdrop" style="display:none"></div>
            <div class="focus-panel" id="focus-panel" style="display:none">
                <div class="focus-panel-content" id="focus-panel-content"></div>
                <div class="focus-panel-controls" id="focus-panel-controls">
                    <button class="focus-panel-btn" id="focus-play-btn" aria-label="Play">
                        <svg id="fp-icon-play" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" style="display:block"><path d="M8 5v14l11-7z"/></svg>
                        <svg id="fp-icon-pause" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                    </button>
                    <button class="focus-panel-btn focus-panel-stop" id="focus-stop-btn" aria-label="Stop" style="display:none">
                        <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h12v12H6z"/></svg>
                    </button>
                </div>
            </div>
        </div>

        <script>
            import * as audioStore from "../scripts/audio-store";

            // Expose for define:vars page scripts
            (window as any).__audioStore = audioStore;

            // iOS audio unlock on first interaction
            const unlockEvents = ["touchstart", "click"] as const;
            function onFirstInteraction() {
                audioStore.unlockAudio();
                for (const evt of unlockEvents) {
                    document.removeEventListener(evt, onFirstInteraction, true);
                }
            }
            for (const evt of unlockEvents) {
                document.addEventListener(evt, onFirstInteraction, true);
            }

            // Mini player UI bindings
            const root = document.getElementById("mini-player-root")!;
            const playerBtn = document.getElementById("mini-player-btn")!;
            const closeBtn = document.getElementById("mini-player-close")!;
            const titleEl = document.getElementById("mini-player-title")!;
            const imageEl = document.getElementById("mini-player-image")!;
            const pulseEl = document.getElementById("mini-player-pulse")!;
            const iconPlay = document.getElementById("mini-player-icon-play")!;
            const iconPause = document.getElementById("mini-player-icon-pause")!;

            playerBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                const state = audioStore.getState();
                if (state.audioPlayState === "idle") {
                    if (state.pausedState) audioStore.resumePlayback();
                } else {
                    audioStore.pausePlayback();
                }
            });

            closeBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                audioStore.stopAll();
            });

            // Click the player card → enter focus mode + navigate to playing chapter
            root.addEventListener("click", () => {
                const state = audioStore.getState();
                if (state.audioContext) {
                    const { learnCode, mtCode, book, chapter } = state.audioContext;
                    const href = `/${learnCode}/${mtCode}/${book}/${chapter}/`;
                    audioStore.setFocusMode(true);
                    if (window.location.pathname !== href) {
                        window.location.href = href;
                    }
                }
            });

            // ── Focus panel bindings ──
            const focusBackdrop = document.getElementById("focus-backdrop")!;
            const focusPanel = document.getElementById("focus-panel")!;
            const focusPanelContent = document.getElementById("focus-panel-content")!;
            const focusPlayBtn = document.getElementById("focus-play-btn")!;
            const focusStopBtn = document.getElementById("focus-stop-btn")!;
            const fpIconPlay = document.getElementById("fp-icon-play")!;
            const fpIconPause = document.getElementById("fp-icon-pause")!;

            // Focus play/pause
            focusPlayBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                const state = audioStore.getState();
                if (state.audioPlayState === "idle") {
                    if (state.pausedState) {
                        audioStore.resumePlayback();
                    } else if (state.cachedPrimaryAudioUrl) {
                        audioStore.playVerse(state.currentVerseIdx);
                    }
                } else {
                    audioStore.pausePlayback();
                }
            });

            // Focus stop
            focusStopBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                audioStore.stopAll();
            });

            // Exit focus mode
            focusBackdrop.addEventListener("click", () => audioStore.setFocusMode(false));
            window.addEventListener("wheel", () => {
                if (audioStore.getState().focusMode) audioStore.setFocusMode(false);
            }, { passive: true });
            focusBackdrop.addEventListener("touchmove", () => {
                audioStore.setFocusMode(false);
            }, { passive: true });
            let focusTouchStartY = 0;
            let focusTouchLastY = 0;
            let focusTouchLastTime = 0;
            focusPanel.addEventListener("touchstart", (e) => {
                focusTouchStartY = e.touches[0].clientY;
                focusTouchLastY = focusTouchStartY;
                focusTouchLastTime = Date.now();
                focusTouchHandled = false;
            }, { passive: true });
            let focusTouchHandled = false;
            focusPanel.addEventListener("touchmove", (e) => {
                if (focusTouchHandled) return;
                const y = e.touches[0].clientY;
                const deltaY = focusTouchLastY - y;
                const now = Date.now();
                const dt = now - focusTouchLastTime;
                const velocity = dt > 0 ? deltaY / dt : 0; // px/ms
                focusTouchLastY = y;
                focusTouchLastTime = now;
                const totalDelta = focusTouchStartY - y;
                if (Math.abs(totalDelta) > 10) {
                    focusTouchHandled = true;
                    const scrollAmount = totalDelta + velocity * 150;
                    audioStore.setFocusMode(false);
                    requestAnimationFrame(() => {
                        requestAnimationFrame(() => {
                            const scroller = document.querySelector(".listen-scroll-area") || document.querySelector(".chapter-content") || document.querySelector(".main-content");
                            if (scroller) {
                                scroller.scrollBy({ top: scrollAmount, behavior: "smooth" });
                            } else {
                                window.scrollBy({ top: scrollAmount, behavior: "smooth" });
                            }
                        });
                    });
                }
            }, { passive: true });

            function populateFocusPanel(idx: number) {
                const state = audioStore.getState();
                const card = audioStore.getPlayerCardInfo();
                const entry = state.verseEntries[idx];
                if (!entry) return;

                const duration = entry.endTime > entry.startTime
                    ? (entry.endTime - entry.startTime) : 10;
                const variant = Math.floor(Math.random() * 4) + 1;

                // Build focus panel content mirroring verse card structure
                let html = "";
                const verseEl = document.getElementById(`verse-${idx}`);
                // Get all images from the verse card DOM
                const verseImages = verseEl?.querySelectorAll(".listen-verse-images img");
                let hasImages = false;
                if (verseImages && verseImages.length > 0) {
                    hasImages = true;
                    html += `<div class="listen-verse-images">`;
                    verseImages.forEach((img) => {
                        const src = (img as HTMLImageElement).src;
                        html += `<div style="overflow:hidden"><img src="${src}" alt="" class="ken-burns-${variant}" style="animation-duration:${duration}s" /></div>`;
                    });
                    html += `<div class="listen-verse-ref">${card.title}</div>`;
                    html += `</div>`;
                } else if (card.imageUrl) {
                    hasImages = true;
                    html += `<div class="listen-verse-images">`;
                    html += `<div style="overflow:hidden"><img src="${card.imageUrl}" alt="" class="ken-burns-${variant}" style="animation-duration:${duration}s" /></div>`;
                    html += `<div class="listen-verse-ref">${card.title}</div>`;
                    html += `</div>`;
                } else {
                    html += `<div class="listen-verse-ref" style="position:static;background:none;color:var(--accent);font-size:0.75rem;font-weight:600;text-transform:none;letter-spacing:normal;text-shadow:none;padding:0.75rem 0.75rem 0;border-radius:0;">${card.title}</div>`;
                }
                if (verseEl) {
                    const priText = verseEl.querySelector(".listen-verse-text-learn") as HTMLElement | null;
                    const secText = verseEl.querySelector(".listen-verse-text-mt") as HTMLElement | null;
                    const priDir = priText?.getAttribute("dir") ? ` dir="${priText.getAttribute("dir")}"` : "";
                    const secDir = secText?.getAttribute("dir") ? ` dir="${secText.getAttribute("dir")}"` : "";
                    if (priText) html += `<div class="listen-verse-text-learn"${priDir}>${priText.innerHTML}</div>`;
                    if (secText) html += `<div class="listen-verse-text-mt"${secDir}>${secText.innerHTML}</div>`;
                }
                focusPanelContent.innerHTML = html;
                focusPanel.scrollTop = 0;
            }

            function showFocusPanel(idx: number) {
                populateFocusPanel(idx);
                focusBackdrop.style.display = "";
                focusPanel.style.display = "";
            }

            function hideFocusPanel() {
                focusBackdrop.style.display = "none";
                focusPanel.style.display = "none";
                focusPanelContent.innerHTML = "";
            }

            // Subscribe to state changes
            let prevFocusMode = false;
            let prevVerseIdx = -1;
            audioStore.subscribe(() => {
                const state = audioStore.getState();
                const card = audioStore.getPlayerCardInfo();
                const isPlaying = state.audioPlayState !== "idle";

                // ── Focus mode transitions ──
                if (state.focusMode && !prevFocusMode) {
                    // Entering focus mode
                    document.body.classList.add("focus-mode");
                    root.style.display = "none"; // hide mini player
                    showFocusPanel(state.currentVerseIdx);
                } else if (!state.focusMode && prevFocusMode) {
                    // Exiting focus mode
                    document.body.classList.remove("focus-mode");
                    hideFocusPanel();
                    if (state.playerVisible) root.style.display = ""; // show mini player
                }
                prevFocusMode = state.focusMode;

                // Update focus panel content when verse changes during focus mode
                if (state.focusMode && state.currentVerseIdx !== prevVerseIdx && isPlaying) {
                    populateFocusPanel(state.currentVerseIdx);
                }
                prevVerseIdx = state.currentVerseIdx;

                // ── Focus panel play/pause icons ──
                fpIconPlay.style.display = isPlaying ? "none" : "block";
                fpIconPause.style.display = isPlaying ? "block" : "none";
                focusStopBtn.style.display = isPlaying ? "none" : "";

                // ── Audio paused class for Ken Burns ──
                if (state.pausedState) {
                    document.body.classList.add("audio-paused");
                } else {
                    document.body.classList.remove("audio-paused");
                }

                // ── Mini player (only when not in focus mode) ──
                if (!state.focusMode) {
                    root.style.display = state.playerVisible ? "" : "none";
                }

                // Play/pause icon
                iconPlay.style.display = isPlaying ? "none" : "block";
                iconPause.style.display = isPlaying ? "block" : "none";

                // Close button only visible when paused
                closeBtn.style.display = state.pausedState ? "" : "none";

                // Pulse
                pulseEl.style.display = isPlaying ? "" : "none";

                // Card info
                titleEl.textContent = card.title;
                if (card.imageUrl) {
                    imageEl.innerHTML = `<img src="${card.imageUrl}" alt="" />`;
                }
            });
        </script>
    </body>
</html>
