---
import fs from "node:fs";
import path from "node:path";
import langsData from "../data/ALL-langs-compact.json";
import { useTranslations } from "../i18n";

const base = "src/data/ALL-langs-data/nt";
const dirs = ["with-timecode", "audio-with-timecode"];
const learnCodes = new Set<string>();

for (const dir of dirs) {
    const fullPath = path.resolve(base, dir);
    if (fs.existsSync(fullPath)) {
        for (const entry of fs.readdirSync(fullPath)) {
            if (/^[a-z]{3}$/.test(entry)) {
                learnCodes.add(entry);
            }
        }
    }
}

// Count mother tongue languages: must have at least one non-failed NT category
const mtCodes = new Set<string>();
const ntCanon = (langsData.canons as any).nt;
if (ntCanon) {
    for (const cat of Object.keys(ntCanon)) {
        if (cat === "failed") continue;
        for (const code of Object.keys(ntCanon[cat])) {
            mtCodes.add(code);
        }
    }
}

const learnCount = learnCodes.size;
const mtCount = mtCodes.size;
const combinations = learnCount * mtCount;
const combinationsFormatted = combinations.toLocaleString("en-US");

const wt = langsData.canons.nt["with-timecode"] as Record<
    string,
    { n?: string; v?: string }
>;
const awt = langsData.canons.nt["audio-with-timecode"] as Record<
    string,
    { n?: string; v?: string }
>;

const languages = [...learnCodes].sort().map((code) => {
    const info = wt[code] || awt[code] || {};
    return { code, name: info.n || code, vernacular: info.v || "" };
});

// Build hero translations for all supported UI locales
const heroLocales = [
    "eng",
    "fra",
    "deu",
    "spa",
    "por",
    "rus",
    "hin",
    "arb",
    "ron",
];
const heroTranslations: Record<string, Record<string, string>> = {};
for (const loc of heroLocales) {
    const t = useTranslations(loc);
    heroTranslations[loc] = {
        heroTagline: t("heroTagline"),
        heroHeadline: t("heroHeadline"),
        heroSub: t("heroSub")
            .replace("{primary}", String(learnCount))
            .replace("{secondary}", mtCount.toLocaleString("en-US")),
        selectMotherTongue: t("selectMotherTongue"),
        selectLanguageToLearn: t("selectLanguageToLearn"),
        searchPlaceholder: t("searchPlaceholder"),
        languageCount: t("languageCount"),
        languageCountFiltered: t("languageCountFiltered"),
        noLanguagesFound: t("noLanguagesFound"),
        motherTongueBadge: t("motherTongueBadge"),
        learningLangBadge: t("learningLangBadge"),
        stepIndicator: t("stepIndicator"),
        screenshotHeading: t("screenshotHeading"),
        screenshotSelectStory: t("screenshotSelectStory"),
        screenshotSelectExercise: t("screenshotSelectExercise"),
        screenshotContinue: t("screenshotContinue"),
    };
}
const heroJSON = JSON.stringify(heroTranslations);

// Build mother tongue languages array for the modal grid
const mtLanguages: { code: string; name: string; vernacular: string }[] =
    [];
const seenSec = new Set<string>();
for (const cat of Object.keys(ntCanon)) {
    if (cat === "failed") continue;
    const catData = ntCanon[cat] as Record<string, { n?: string; v?: string }>;
    for (const [lc, info] of Object.entries(catData)) {
        if (!seenSec.has(lc)) {
            seenSec.add(lc);
            mtLanguages.push({
                code: lc,
                name: info.n || lc,
                vernacular: info.v || "",
            });
        }
    }
}
mtLanguages.sort((a, b) => a.name.localeCompare(b.name));

const langDataJSON = JSON.stringify({
    learn: languages,
    mt: mtLanguages,
});
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="dark" />
        <title>Duo Bibel Wiki</title>
        <style>
            :root {
                --bg: #ffffff;
                --bg-surface: rgba(0, 0, 0, 0.04);
                --bg-surface-hover: rgba(0, 0, 0, 0.08);
                --text: #1a1a2e;
                --text-secondary: #555;
                --text-muted: #888;
                --text-on-accent: #fff;
                --accent: #5b9bd5;
                --accent-hover: #4a8bc4;
                --border: rgba(0, 0, 0, 0.1);
                --border-strong: rgba(0, 0, 0, 0.2);
                --shadow: rgba(0, 0, 0, 0.15);
                --shadow-strong: rgba(0, 0, 0, 0.3);
                --success-bright: #22cc00;
            }
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                font-family:
                    system-ui,
                    -apple-system,
                    sans-serif;
                min-height: 100vh;
                min-height: 100dvh;
                background: var(--bg);
                color: var(--text);
            }

            /* ── Header ── */
            .app-header {
                background: #007bff;
                color: white;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
                position: sticky;
                top: 0;
                z-index: 50;
            }
            .header-content {
                max-width: 1200px;
                margin: 0 auto;
                padding: 1rem 1.5rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .app-title {
                font-size: 1.5rem;
                font-weight: 600;
            }
            .language-button {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.5rem 1rem;
                background: var(--bg-surface);
                border: 1px solid var(--border-strong);
                border-radius: 6px;
                color: white;
                font-size: 1rem;
                cursor: pointer;
                transition: all 0.2s;
                min-height: 44px;
            }
            .language-button:hover {
                background: var(--bg-surface-hover);
            }
            .language-icon {
                font-size: 1.1rem;
                line-height: 1;
            }
            .language-text {
                font-weight: 500;
            }
            /* Lang pair buttons (JS-injected in continue-view) */
            :global(.header-langs) {
                display: flex;
                gap: 0.5rem;
                align-items: center;
            }
            :global(.language-button.compact) {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.4rem 0.6rem;
                min-height: 36px;
                background: var(--bg-surface);
                border: 1px solid var(--border-strong);
                border-radius: 6px;
                color: white;
                font-size: 1rem;
                cursor: pointer;
                transition: all 0.2s;
                text-decoration: none;
            }
            :global(.language-button.compact:hover) {
                background: var(--bg-surface-hover);
            }
            :global(.language-icon-wrapper) {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 0.15rem;
                flex-shrink: 0;
            }
            :global(.language-code-label) {
                font-size: 0.55rem;
                font-family: monospace;
                font-weight: 600;
                text-transform: uppercase;
                line-height: 1;
                opacity: 0.8;
            }
            :global(.lang-pair-arrow) {
                font-size: 1.1rem;
                opacity: 0.7;
                flex-shrink: 0;
            }
            :global(.lang-pair-name) {
                font-weight: 500;
                white-space: nowrap;
            }
            @media (max-width: 768px) {
                :global(.lang-pair-name) {
                    display: none;
                }
            }

            /* ── Hero ── */
            .hero {
                text-align: center;
                padding: 4rem 1.5rem 3rem;
                max-width: 800px;
                margin: 0 auto;
            }
            .hero-tagline {
                font-size: 0.9rem;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                color: #6ea8fe;
                margin-bottom: 1.25rem;
                font-weight: 600;
            }
            .hero-headline {
                font-size: clamp(2rem, 6vw, 3.5rem);
                font-weight: 700;
                line-height: 1.15;
                margin-bottom: 1.5rem;
                background: linear-gradient(135deg, #ffffff 0%, #6ea8fe 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }
            .hero-sub {
                font-size: clamp(1rem, 2.5vw, 1.25rem);
                color: var(--text-secondary);
                line-height: 1.6;
                max-width: 600px;
                margin: 0 auto 2.5rem;
            }
            .hero-cta {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.9rem 2rem;
                background: #007bff;
                color: white;
                border: none;
                border-radius: 8px;
                font-size: 1.1rem;
                font-weight: 600;
                cursor: pointer;
                transition:
                    background 0.2s,
                    transform 0.1s;
            }
            .hero-cta:hover {
                background: #0056b3;
            }
            .hero-cta:active {
                transform: scale(0.98);
            }

            /* ── Big number ── */
            .big-number-section {
                text-align: center;
                padding: 2rem 1.5rem 3rem;
            }
            .big-number {
                font-size: clamp(3rem, 10vw, 5.5rem);
                font-weight: 800;
                background: linear-gradient(135deg, #6ea8fe 0%, #4caf50 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                line-height: 1.1;
            }
            .big-number-label {
                font-size: clamp(1rem, 2.5vw, 1.3rem);
                color: var(--text-secondary);
                margin-top: 0.5rem;
            }

            /* ── Stats row ── */
            .stats {
                display: flex;
                justify-content: center;
                gap: 2rem;
                padding: 2rem 1.5rem 3rem;
                max-width: 700px;
                margin: 0 auto;
            }
            .stat {
                text-align: center;
                flex: 1;
            }
            .stat-value {
                font-size: clamp(1.5rem, 4vw, 2.25rem);
                font-weight: 700;
                color: var(--text-on-accent);
            }
            .stat-label {
                font-size: 0.85rem;
                color: var(--text-muted);
                margin-top: 0.35rem;
            }
            .stat-divider {
                width: 1px;
                background: var(--bg-surface);
                align-self: stretch;
            }

            /* ── Screenshots ── */
            .screenshots {
                padding: 2rem 1.5rem 4rem;
                max-width: 1000px;
                margin: 0 auto;
            }
            .screenshots-heading {
                text-align: center;
                font-size: 1.1rem;
                color: var(--text-muted);
                margin-bottom: 2rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                font-weight: 600;
            }
            .screenshots-row {
                display: flex;
                gap: 1.5rem;
                justify-content: center;
            }
            .screenshot-card {
                flex: 0 0 auto;
                width: 220px;
            }
            .screenshot-img {
                width: 100%;
                border-radius: 16px;
                display: block;
            }
            .screenshot-caption {
                text-align: center;
                margin-top: 0.75rem;
                font-size: 0.9rem;
                color: var(--text-secondary);
            }
            .carousel-steps {
                display: none;
            }

            /* ── Modal overlay ── */
            .modal-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.7);
                z-index: 100;
                align-items: flex-start;
                justify-content: center;
                padding: 2rem 1rem;
                overflow-y: auto;
            }
            .modal-overlay.open {
                display: flex;
            }
            .modal {
                background: var(--bg);
                border-radius: 12px;
                border: 1px solid var(--border);
                width: 100%;
                max-width: 900px;
                max-height: calc(100vh - 4rem);
                max-height: calc(100dvh - 4rem);
                display: flex;
                flex-direction: column;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
            }
            .modal-header {
                position: relative;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 0.75rem 3rem 0;
                background: #007bff;
                color: white;
                flex-shrink: 0;
            }
            .modal-header h2 {
                font-size: 1.25rem;
                text-align: center;
                color: white;
            }
            .modal-back {
                position: absolute;
                left: 1rem;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                color: var(--text);
                font-size: 1.25rem;
                cursor: pointer;
                padding: 0.25rem 0.5rem;
                border-radius: 4px;
                transition:
                    color 0.2s,
                    background 0.2s;
                line-height: 1;
            }
            .modal-back:hover {
                color: white;
                background: var(--bg-surface);
            }
            .header-pills {
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                align-items: center;
                gap: 0.5rem;
                padding: 0.5rem 1.5rem;
                background: #007bff;
                flex-shrink: 0;
            }
            .selected-badge {
                display: none;
                align-items: center;
                gap: 0.4rem;
                background: white;
                color: #007bff;
                font-weight: 600;
                padding: 0.25rem 0.7rem;
                border-radius: 10px;
                font-size: 0.85rem;
                border: none;
                white-space: nowrap;
            }
            .step-indicator {
                font-size: 0.85rem;
                font-weight: 600;
                color: #007bff;
                background: white;
                padding: 0.25rem 0.7rem;
                border-radius: 10px;
                white-space: nowrap;
            }
            .modal-close {
                position: absolute;
                right: 1rem;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                color: var(--text);
                font-size: 1.5rem;
                cursor: pointer;
                padding: 0.25rem 0.5rem;
                border-radius: 4px;
                transition:
                    color 0.2s,
                    background 0.2s;
                line-height: 1;
            }
            .modal-close:hover {
                color: white;
                background: var(--bg-surface);
            }
            .modal-sticky {
                padding: 0.75rem 1.5rem 0;
                flex-shrink: 0;
                border-bottom: 1px solid var(--border);
                text-align: center;
            }
            .modal-body {
                padding: 0.75rem 1.5rem 1rem;
                overflow-y: auto;
                flex: 1;
            }

            /* ── Language selector (modal) ── */
            .search-section {
                max-width: 500px;
                margin: 0 auto 1rem;
            }
            .search-input {
                width: 100%;
                padding: 0.85rem 1.15rem;
                font-size: 1.1rem;
                border: 2px solid rgba(80, 180, 220, 0.6);
                border-radius: 8px;
                outline: none;
                box-sizing: border-box;
                transition: border-color 0.2s, box-shadow 0.2s;
                background: rgb(182 231 252 / 94%);
                color: #111;
            }
            .search-input::placeholder {
                color: rgba(0, 0, 0, 0.45);
            }
            .search-input:focus {
                border-color: #4cc4f0;
                box-shadow: 0 0 0 3px rgba(110, 204, 244, 0.3);
            }
            .count {
                text-align: center;
                color: var(--text-muted);
                margin: 0.5rem 0 1.25rem;
                font-size: 0.95rem;
            }
            .no-results {
                text-align: center;
                color: var(--text-muted);
                padding: 3rem 1rem;
                font-size: 1.1rem;
            }
            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
                gap: 0.5rem;
            }
            /* Grid items are JS-generated — need :global */
            :global(.lang-item) {
                display: flex;
                align-items: baseline;
                gap: 0.5rem;
                padding: 0.6rem 0.85rem;
                background: var(--bg-surface);
                border-radius: 6px;
                color: var(--text);
                transition: background 0.15s;
                border: 1px solid var(--border);
                cursor: pointer;
            }
            :global(.lang-item:hover) {
                background: var(--bg-surface-hover);
                border-color: rgba(110, 168, 254, 0.4);
            }
            :global(.lang-code) {
                color: var(--text-muted);
                font-size: 0.8rem;
                font-family: monospace;
                flex-shrink: 0;
            }
            :global(.lang-name) {
                font-weight: 500;
            }
            :global(.lang-vernacular) {
                color: #6ea8fe;
                font-size: 0.85rem;
            }
            :global(.highlight) {
                background: rgba(110, 168, 254, 0.25);
                color: #6ea8fe;
                border-radius: 2px;
            }

            /* ── Continue view (hero card) ── */
            .continue-view {
                display: none;
                flex-direction: column;
                align-items: center;
                padding: 1.5rem 1rem 2rem;
            }
            .continue-view.visible {
                display: flex;
            }
            .continue-welcome {
                font-size: 0.95rem;
                color: var(--text-secondary);
                margin-bottom: 1rem;
                letter-spacing: 0.03em;
            }
            .hero-card {
                position: relative;
                max-width: 480px;
                width: 100%;
                border-radius: 16px;
                overflow: hidden;
                box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
                cursor: pointer;
                transition: transform 0.2s, box-shadow 0.2s;
            }
            .hero-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 16px 48px rgba(0, 0, 0, 0.6);
            }
            .hero-card:active {
                transform: scale(0.99);
            }
            .hero-card-img {
                width: 100%;
                aspect-ratio: 16 / 10;
                object-fit: cover;
                display: block;
            }
            .hero-card-overlay {
                position: absolute;
                left: 0;
                right: 0;
                bottom: 0;
                background: linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.75) 0%,
                    rgba(0, 0, 0, 0.3) 60%,
                    transparent 100%
                );
                display: flex;
                flex-direction: column;
                justify-content: flex-end;
                padding: 0.75rem 1.25rem;
            }
            .hero-card-info {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                flex-wrap: wrap;
            }
            .hero-card-badge {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                background: rgba(91, 155, 213, 0.3);
                border: 1px solid rgba(91, 155, 213, 0.5);
                color: #8ec5fc;
                font-size: 0.7rem;
                font-weight: 600;
                padding: 0.15rem 0.5rem;
                border-radius: 6px;
                text-transform: uppercase;
                letter-spacing: 0.04em;
            }
            .hero-card-ref {
                font-size: 1rem;
                font-weight: 700;
                color: #fff;
            }
            .hero-card-exercise {
                font-size: 0.75rem;
                color: rgba(255,255,255,0.6);
            }
            .hero-card-progress {
                margin-top: 0.5rem;
                height: 3px;
                background: var(--bg-surface);
                border-radius: 2px;
                overflow: hidden;
            }
            .hero-card-progress-bar {
                height: 100%;
                background: #22ff00;
                border-radius: 2px;
                transition: width 0.3s;
            }
            .continue-cta {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                margin-top: 1.25rem;
                max-width: 480px;
                width: 100%;
                padding: 0.9rem;
                background: #5b9bd5;
                color: #fff;
                font-size: 1.05rem;
                font-weight: 700;
                border: none;
                border-radius: 12px;
                cursor: pointer;
                transition: background 0.15s, transform 0.1s;
                text-decoration: none;
            }
            .continue-cta:hover {
                background: #4a8bc4;
            }
            .continue-cta:active {
                transform: scale(0.98);
            }
            .continue-secondary {
                display: flex;
                gap: 1.5rem;
                margin-top: 1rem;
            }
            .continue-secondary-btn {
                background: none;
                border: none;
                color: var(--text-muted);
                font-size: 0.8rem;
                cursor: pointer;
                padding: 0.4rem 0;
                transition: color 0.2s;
            }
            .continue-secondary-btn:hover {
                color: var(--text-secondary);
            }
            /* ── Recently studied row (JS-generated, needs :global) ── */
            .history-section {
                width: 100%;
                max-width: 480px;
                margin-top: 1.75rem;
            }
            .history-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 0.6rem;
            }
            .history-label {
                font-size: 0.8rem;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 0.06em;
            }
            .history-clear {
                background: none;
                border: none;
                color: var(--text-muted);
                font-size: 0.75rem;
                cursor: pointer;
                padding: 0;
                transition: color 0.2s;
            }
            .history-clear:hover {
                color: var(--text-secondary);
            }
            :global(.history-row) {
                display: flex;
                gap: 0.6rem;
                overflow-x: auto;
                scrollbar-width: none;
                -ms-overflow-style: none;
                padding-bottom: 0.25rem;
            }
            :global(.history-row)::-webkit-scrollbar {
                display: none;
            }
            :global(.history-card) {
                position: relative;
                flex-shrink: 0;
                width: 120px;
                border-radius: 10px;
                overflow: hidden;
                background: var(--bg-surface);
                border: 1px solid var(--border);
                text-decoration: none;
                color: var(--text);
                transition: background 0.15s, border-color 0.15s;
            }
            :global(.history-card-close) {
                position: absolute;
                top: 2px;
                right: 2px;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: rgba(0, 0, 0, 0.6);
                border: none;
                color: var(--text);
                font-size: 0.7rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                opacity: 0;
                transition: opacity 0.15s;
                z-index: 1;
            }
            :global(.history-card:hover .history-card-close) {
                opacity: 1;
            }
            :global(.history-card-close:hover) {
                background: rgba(0, 0, 0, 0.8);
                color: #fff;
            }
            :global(.history-card:hover) {
                background: var(--bg-surface-hover);
                border-color: rgba(91, 155, 213, 0.4);
            }
            :global(.history-card-img) {
                width: 100%;
                aspect-ratio: 16 / 10;
                object-fit: cover;
                display: block;
            }
            :global(.history-card-body) {
                padding: 0.35rem 0.45rem;
            }
            :global(.history-card-ref) {
                font-size: 0.7rem;
                font-weight: 600;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }
            :global(.history-card-langs) {
                font-size: 0.6rem;
                color: var(--text-muted);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .landing-content.hidden {
                display: none;
            }

            /* ── Responsive ── */
            @media (max-width: 768px) {
                .header-content {
                    padding: 0.75rem 1rem;
                }
                .app-title {
                    font-size: 1.25rem;
                }
                .language-button {
                    padding: 0.4rem 0.5rem;
                    font-size: 0.875rem;
                    gap: 0.5rem;
                }
                .language-text {
                    display: none;
                }
                .hero {
                    padding: 3rem 1.25rem 2rem;
                }
                .stats {
                    gap: 1rem;
                    padding: 1.5rem 1rem 2rem;
                }
                .screenshots {
                    padding: 1.5rem 0 3rem;
                    overflow: hidden;
                }
                .screenshots-row {
                    gap: 0;
                    justify-content: flex-start;
                    transition: transform 0.4s ease;
                    will-change: transform;
                }
                .screenshot-card {
                    width: 65%;
                    flex-shrink: 0;
                    transition:
                        transform 0.4s ease,
                        opacity 0.4s ease;
                    opacity: 0.4;
                    transform: scale(0.85);
                }
                .screenshot-card.active {
                    opacity: 1;
                    transform: scale(1);
                }
                .screenshot-caption {
                    opacity: 0;
                    transition: opacity 0.4s ease;
                }
                .screenshot-card.active .screenshot-caption {
                    opacity: 1;
                }
                .carousel-steps {
                    display: flex;
                    justify-content: center;
                    gap: 1.25rem;
                    margin-top: 1.25rem;
                }
                .carousel-step {
                    width: 28px;
                    height: 28px;
                    border-radius: 50%;
                    border: 2px solid var(--border-strong);
                    background: transparent;
                    color: var(--text-muted);
                    font-size: 0.8rem;
                    font-weight: 600;
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    transition: all 0.3s ease;
                    padding: 0;
                }
                .carousel-step.active {
                    border-color: #5b9bd5;
                    background: #5b9bd5;
                    color: #fff;
                }
                .modal-overlay {
                    padding: 1rem 0.5rem;
                }
                .modal-body {
                    padding: 1rem;
                }
                .grid {
                    grid-template-columns: 1fr;
                }
            }
        </style>
    </head>
    <body>
        <!-- Header -->
        <header class="app-header">
            <div class="header-content">
                <h1 class="app-title">Duo Bibel Wiki</h1>
                <button class="language-button" id="open-lang-selector">
                    <span class="language-icon">🌐</span>
                    <span class="language-text">Select language</span>
                </button>
            </div>
        </header>

        <!-- Continue view (shown when saved state exists) -->
        <div class="continue-view" id="continue-view">
            <div class="continue-welcome">Welcome back</div>
            <a class="hero-card" id="continue-link">
                <img class="hero-card-img" id="continue-image" src="" alt="" />
                <div class="hero-card-overlay">
                    <div class="hero-card-info">
                        <div class="hero-card-ref" id="continue-ref"></div>
                        <div class="hero-card-badge" id="continue-langs"></div>
                        <div class="hero-card-exercise" id="continue-exercise"></div>
                    </div>
                    <div class="hero-card-progress">
                        <div class="hero-card-progress-bar" id="continue-progress" style="width:0%"></div>
                    </div>
                </div>
            </a>
            <a class="continue-cta" id="continue-cta">
                Continue &rarr;
            </a>
            <div class="continue-secondary">
                <button class="continue-secondary-btn" id="continue-reset">Start fresh</button>
                <button class="continue-secondary-btn" id="continue-change">Change language</button>
            </div>
            <div class="history-section" id="history-section" style="display:none">
                <div class="history-header">
                    <div class="history-label">Recently studied</div>
                    <button class="history-clear" id="history-clear">Clear all</button>
                </div>
                <div class="history-row" id="history-row"></div>
            </div>
        </div>

        <!-- Landing content -->
        <div class="landing-content" id="landing-content">
            <!-- Hero -->
            <section class="hero">
                <p class="hero-tagline" id="hero-tagline">
                    Easy language learning
                </p>
                <h2 class="hero-headline" id="hero-headline">
                    The unmatched multilingual learning experience
                </h2>
                <p class="hero-sub" id="hero-sub">
                    Listen to any of {learnCount} languages - with exercises in
                    {mtCount.toLocaleString("en-US")} mother-tongues
                </p>
                <button class="hero-cta" id="hero-cta">
                    <span id="hero-cta-text">Select language to learn</span>
                    <span>&rarr;</span>
                </button>
            </section>

            <!-- Big number -->
            <section class="big-number-section">
                <div class="big-number">{combinationsFormatted}</div>
                <p class="big-number-label">possible language combinations</p>
            </section>

            <!-- Stats -->
            <section class="stats">
                <div class="stat">
                    <div class="stat-value">{learnCount}</div>
                    <div class="stat-label">learn languages</div>
                </div>
                <div class="stat-divider"></div>
                <div class="stat">
                    <div class="stat-value">
                        {mtCount.toLocaleString("en-US")}
                    </div>
                    <div class="stat-label">mother-tongue languages</div>
                </div>
                <div class="stat-divider"></div>
                <div class="stat">
                    <div class="stat-value">1.2M+</div>
                    <div class="stat-label">combinations</div>
                </div>
            </section>

            <!-- Screenshots -->
            <section class="screenshots">
                <p class="screenshots-heading" id="screenshots-heading">
                    How it works
                </p>
                <div class="screenshots-row">
                    <div class="screenshot-card">
                        <img
                            class="screenshot-img"
                            src="/screenshots/step1.png"
                            alt="Select a story"
                        />
                        <p class="screenshot-caption" id="caption-1">
                            Select a story
                        </p>
                    </div>
                    <div class="screenshot-card">
                        <img
                            class="screenshot-img"
                            src="/screenshots/step2.png"
                            alt="Select an exercise"
                        />
                        <p class="screenshot-caption" id="caption-2">
                            Select an exercise
                        </p>
                    </div>
                    <div class="screenshot-card">
                        <img
                            class="screenshot-img"
                            src="/screenshots/step3.png"
                            alt="Continue"
                        />
                        <p class="screenshot-caption" id="caption-3">
                            Continue
                        </p>
                    </div>
                </div>
                <div class="carousel-steps" id="carousel-steps">
                    <button class="carousel-step active" data-slide="0"
                        >1</button
                    >
                    <button class="carousel-step" data-slide="1">2</button>
                    <button class="carousel-step" data-slide="2">3</button>
                </div>
            </section>
        </div><!-- end landing-content -->

        <!-- Language selector modal -->
        <div class="modal-overlay" id="modal-overlay">
            <div class="modal">
                <div class="modal-header">
                    <button
                        class="modal-back"
                        id="modal-back"
                        aria-label="Back"
                        style="display:none">&larr;</button
                    >
                    <h2 id="modal-title"></h2>
                    <button
                        class="modal-close"
                        id="modal-close"
                        aria-label="Close">&times;</button
                    >
                </div>
                <div class="header-pills">
                    <div
                        id="selected-badge"
                        class="selected-badge"
                        style="display:none"
                    >
                    </div>
                    <span class="step-indicator" id="step-indicator"></span>
                </div>
                <div class="modal-sticky">
                    <div class="search-section">
                        <input
                            id="search"
                            class="search-input"
                            type="text"
                            placeholder=""
                        />
                    </div>
                    <p class="count" id="count"></p>
                </div>
                <div class="modal-body">
                    <div class="grid" id="grid"></div>
                    <p class="no-results" id="no-results" style="display:none">
                    </p>
                </div>
            </div>
        </div>

        <script id="hero-i18n" type="application/json" set:html={heroJSON} />
        <script
            id="lang-data"
            type="application/json"
            set:html={langDataJSON}
        />
        <script>
            // Localise UI based on browser language
            const LANG_MAP: Record<string, string> = {
                en: "eng",
                fr: "fra",
                de: "deu",
                es: "spa",
                pt: "por",
                ru: "rus",
                hi: "hin",
                ar: "arb",
                ro: "ron",
            };
            const allI18n = JSON.parse(
                document.getElementById("hero-i18n")!.textContent!,
            );
            const browserLang = (navigator.language || "en")
                .split("-")[0]
                .toLowerCase();
            const loc = LANG_MAP[browserLang];
            const ui = (loc && allI18n[loc]) || allI18n["eng"] || {};

            try {
                if (loc && allI18n[loc]) {
                    document.getElementById("hero-tagline")!.textContent =
                        ui.heroTagline;
                    document.getElementById("hero-headline")!.textContent =
                        ui.heroHeadline;
                    document.getElementById("hero-sub")!.textContent =
                        ui.heroSub;
                    document.getElementById("hero-cta-text")!.textContent =
                        ui.selectLanguageToLearn;
                    document.getElementById(
                        "screenshots-heading",
                    )!.textContent = ui.screenshotHeading;
                    document.getElementById("caption-1")!.textContent =
                        ui.screenshotSelectStory;
                    document.getElementById("caption-2")!.textContent =
                        ui.screenshotSelectExercise;
                    document.getElementById("caption-3")!.textContent =
                        ui.screenshotContinue;
                }
            } catch (e) {}

            // Build code → vernacular lookup from lang data
            const _ld = JSON.parse(document.getElementById("lang-data")!.textContent!);
            const vernMap: Record<string, string> = {};
            for (const l of [..._ld.learn, ..._ld.mt]) {
                if (!vernMap[l.code]) vernMap[l.code] = l.vernacular || l.name || l.code;
            }
            function getVern(code: string): string {
                return vernMap[code] || code;
            }

            // Check for saved state and show continue view
            const lastState = localStorage.getItem("lastState");
            if (lastState) {
                try {
                    const state = JSON.parse(lastState);
                    if (state.url && state.imageUrl) {
                        const continueView =
                            document.getElementById("continue-view")!;
                        const landingContent =
                            document.getElementById("landing-content")!;
                        const continueLink = document.getElementById(
                            "continue-link",
                        ) as HTMLAnchorElement;
                        const continueCta = document.getElementById(
                            "continue-cta",
                        ) as HTMLAnchorElement;
                        const continueImage = document.getElementById(
                            "continue-image",
                        ) as HTMLImageElement;
                        const continueLangs =
                            document.getElementById("continue-langs")!;
                        const continueRef =
                            document.getElementById("continue-ref")!;
                        const continueExercise =
                            document.getElementById("continue-exercise")!;
                        const continueProgress =
                            document.getElementById("continue-progress")!;
                        const continueReset =
                            document.getElementById("continue-reset")!;
                        const continueChange =
                            document.getElementById("continue-change")!;

                        continueLink.href = state.url;
                        continueCta.href = state.url;
                        continueImage.src = state.imageUrl;
                        continueLangs.textContent = `${state.lang} \u2190 ${state.lang2}`;
                        continueRef.textContent = state.reference || "";

                        // Exercise type label
                        if (state.exercise) {
                            const labels: Record<string, string> = {
                                listen: "Listening",
                                read: "Reading",
                                speak: "Speaking",
                                write: "Writing",
                                quiz: "Quiz",
                            };
                            const exName = state.exercise.replace(/^exercise-/, "");
                            continueExercise.textContent = labels[exName] || exName;
                        }

                        // Achievement progress for active exercise in this chapter
                        const EX_KEY_MAP: Record<string, string> = { "listen-fill": "f", "listen-order": "o", "sentence-builder": "s" };
                        const refMatch = (state.reference || "").match(/^(\w+)\s+(\d+)/);
                        if (refMatch) {
                            const bookName = refMatch[1];
                            const chNum = refMatch[2];
                            const exKey = EX_KEY_MAP[localStorage.getItem("activeExercise") || "listen-fill"] || "f";
                            const aKey = "a:" + state.lang + "/" + state.lang2 + "/" + bookName + "/" + chNum;
                            try {
                                const ach = JSON.parse(localStorage.getItem(aKey) || "{}");
                                const done = (ach[exKey] || []).length;
                                const total = ach.t || 0;
                                if (total > 0) {
                                    const pct = Math.min(Math.round((done / total) * 100), 100);
                                    continueProgress.style.width = pct + "%";
                                }
                            } catch (e) {}
                        }

                        continueView.classList.add("visible");
                        landingContent.classList.add("hidden");

                        // Inject lang pair buttons into header
                        const existingBtn = document.getElementById("open-lang-selector");
                        if (existingBtn) {
                            const langPairDiv = document.createElement("div");
                            langPairDiv.className = "header-langs";
                            langPairDiv.innerHTML = `<a class="language-button compact" href="/">`
                                + `<div class="language-icon-wrapper"><span class="language-icon">\uD83C\uDF10</span>`
                                + `<span class="language-code-label">${state.lang}</span></div>`
                                + `<span class="lang-pair-name">${getVern(state.lang)}</span></a>`
                                + `<a class="language-button compact" href="/${state.lang}">`
                                + `<span class="lang-pair-arrow">\u2190</span>`
                                + `<div class="language-icon-wrapper"><span class="language-icon">\uD83C\uDF10</span>`
                                + `<span class="language-code-label">${state.lang2}</span></div>`
                                + `<span class="lang-pair-name">${getVern(state.lang2)}</span></a>`;
                            existingBtn.replaceWith(langPairDiv);
                        }

                        continueReset.addEventListener("click", () => {
                            localStorage.removeItem("lastState");
                            localStorage.removeItem("activeExercise");
                            localStorage.removeItem("studyHistory");
                            continueView.classList.remove("visible");
                            landingContent.classList.remove("hidden");
                        });

                        continueChange.addEventListener("click", () => {
                            continueView.classList.remove("visible");
                            landingContent.classList.remove("hidden");
                        });

                        // Populate recently studied row
                        try {
                            const hist = JSON.parse(localStorage.getItem("studyHistory") || "[]");
                            // Skip the first entry (it's the hero card)
                            const older = hist.slice(1).filter((h: any) => h.imageUrl);
                            if (older.length > 0) {
                                const histSection = document.getElementById("history-section")!;
                                const histRow = document.getElementById("history-row")!;
                                for (let i = 0; i < older.length; i++) {
                                    const h = older[i];
                                    const card = document.createElement("a");
                                    card.className = "history-card";
                                    card.href = h.url;
                                    card.innerHTML = `<button class="history-card-close" data-idx="${i + 1}">\u00d7</button>`
                                        + `<img class="history-card-img" src="${h.imageUrl}" alt="" />`
                                        + `<div class="history-card-body">`
                                        + `<div class="history-card-ref">${h.reference || ""}</div>`
                                        + `<div class="history-card-langs">${h.lang} \u2190 ${h.lang2}</div>`
                                        + `</div>`;
                                    histRow.appendChild(card);
                                }
                                histSection.style.display = "";

                                // Per-card × close
                                histRow.addEventListener("click", function(e) {
                                    var btn = (e.target as HTMLElement).closest(".history-card-close") as HTMLElement | null;
                                    if (!btn) return;
                                    e.preventDefault();
                                    e.stopPropagation();
                                    var idx = parseInt(btn.dataset.idx!, 10);
                                    try {
                                        var h2 = JSON.parse(localStorage.getItem("studyHistory") || "[]");
                                        h2.splice(idx, 1);
                                        localStorage.setItem("studyHistory", JSON.stringify(h2));
                                    } catch (ex) {}
                                    var card2 = btn.closest(".history-card") as HTMLElement;
                                    if (card2) card2.remove();
                                    if (histRow.children.length === 0) histSection.style.display = "none";
                                });

                                // Clear all
                                document.getElementById("history-clear")!.addEventListener("click", function() {
                                    try {
                                        var h2 = JSON.parse(localStorage.getItem("studyHistory") || "[]");
                                        localStorage.setItem("studyHistory", JSON.stringify(h2.slice(0, 1)));
                                    } catch (ex) {}
                                    histRow.innerHTML = "";
                                    histSection.style.display = "none";
                                });
                            }
                        } catch (e) {}
                    }
                } catch (e) {
                    localStorage.removeItem("lastState");
                }
            }

            // ── Language data ──
            const langData = JSON.parse(
                document.getElementById("lang-data")!.textContent!,
            );
            const learnLangs = langData.learn;
            const mtLangs = langData.mt;

            // ── DOM refs ──
            const overlay = document.getElementById("modal-overlay")!;
            const openBtn = document.getElementById("open-lang-selector")!;
            const heroCta = document.getElementById("hero-cta")!;
            const closeBtn = document.getElementById("modal-close")!;
            const backBtn = document.getElementById("modal-back")!;
            const modalTitle = document.getElementById("modal-title")!;
            const selectedBadge = document.getElementById("selected-badge")!;
            const stepIndicator = document.getElementById("step-indicator")!;
            const search = document.getElementById(
                "search",
            ) as HTMLInputElement;
            const grid = document.getElementById("grid")!;
            const countEl = document.getElementById("count")!;
            const noResults = document.getElementById("no-results")!;
            noResults.textContent = ui.noLanguagesFound || "No languages found";

            // ── State ──
            let step = 1;
            let selectedPrimary: {
                code: string;
                name: string;
                vernacular: string;
            } | null = null;

            // ── Grid rendering ──
            function renderGrid(langs: typeof learnLangs) {
                let html = "";
                for (const lang of langs) {
                    const vern = lang.vernacular
                        ? ` <span class="lang-vernacular"> - ${lang.vernacular}</span>`
                        : "";
                    html += `<div class="lang-item" data-code="${lang.code}" data-name="${lang.name}" data-vernacular="${lang.vernacular || ""}"><span class="lang-code">${lang.code}</span><span class="lang-name">${lang.name}</span>${vern}</div>`;
                }
                grid.innerHTML = html;
                countEl.textContent = (
                    ui.languageCount || "{count} languages"
                ).replace("{count}", String(langs.length));
                noResults.style.display = "none";
                grid.style.display = "";
            }

            function showStep(s: number) {
                step = s;
                search.value = "";
                search.placeholder =
                    ui.searchPlaceholder ||
                    "Search by language name, vernacular, or code...";
                stepIndicator.textContent = (
                    ui.stepIndicator || "Step {current} of {total}"
                )
                    .replace("{current}", String(s))
                    .replace("{total}", "2");
                if (step === 1) {
                    modalTitle.textContent =
                        ui.selectLanguageToLearn || "Select language to learn";
                    backBtn.style.display = "none";
                    selectedBadge.style.display = "none";
                    renderGrid(learnLangs);
                } else {
                    modalTitle.textContent =
                        ui.selectMotherTongue || "Select mother-tongue";
                    backBtn.style.display = "";
                    selectedBadge.style.display = "flex";
                    const label = selectedPrimary!.vernacular
                        ? `${selectedPrimary!.name} - ${selectedPrimary!.vernacular}`
                        : selectedPrimary!.name;
                    selectedBadge.textContent = (
                        ui.learningLangBadge || "Learning: {label}"
                    ).replace("{label}", label);
                    renderGrid(mtLangs);
                }
                search.focus();
            }

            // ── Grid click handler ──
            grid.addEventListener("click", (e) => {
                const item = (e.target as HTMLElement).closest(
                    ".lang-item",
                ) as HTMLElement | null;
                if (!item) return;
                const code = item.dataset.code!;
                const name = item.dataset.name!;
                const vernacular = item.dataset.vernacular || "";

                if (step === 1) {
                    selectedPrimary = { code, name, vernacular };
                    showStep(2);
                } else {
                    window.location.href = `/${selectedPrimary!.code}/${code}`;
                }
            });

            // ── Modal open/close ──
            function openModal() {
                if (!selectedPrimary) {
                    showStep(1);
                } else {
                    showStep(2);
                }
                overlay.classList.add("open");
                search.focus();
            }
            function closeModal() {
                overlay.classList.remove("open");
            }

            openBtn.addEventListener("click", openModal);
            heroCta.addEventListener("click", openModal);
            closeBtn.addEventListener("click", closeModal);
            backBtn.addEventListener("click", () => showStep(1));
            overlay.addEventListener("click", (e) => {
                if (e.target === overlay) closeModal();
            });
            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape") closeModal();
            });

            // ── Search filtering ──
            function escapeRegex(s: string) {
                return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
            }
            function highlightText(text: string, regex: RegExp | null): string {
                if (!regex) return text;
                return text.replace(
                    regex,
                    (m) => `<span class="highlight">${m}</span>`,
                );
            }

            search.addEventListener("input", () => {
                const items = [
                    ...grid.querySelectorAll<HTMLElement>(".lang-item"),
                ];
                const total = items.length;
                const term = search.value.trim().toLowerCase();

                if (!term) {
                    items.forEach((el) => {
                        el.style.display = "";
                        el.querySelector(".lang-code")!.textContent =
                            el.dataset.code!;
                        el.querySelector(".lang-name")!.textContent =
                            el.dataset.name!;
                        const vEl = el.querySelector(".lang-vernacular");
                        if (vEl)
                            vEl.textContent = ` - ${el.dataset.vernacular!}`;
                    });
                    countEl.textContent = (
                        ui.languageCount || "{count} languages"
                    ).replace("{count}", String(total));
                    noResults.style.display = "none";
                    grid.style.display = "";
                    return;
                }

                const regex = new RegExp(`(${escapeRegex(term)})`, "gi");
                let visible = 0;

                items.forEach((el) => {
                    const code = el.dataset.code!;
                    const name = el.dataset.name!;
                    const vernacular = el.dataset.vernacular || "";
                    const match =
                        code.toLowerCase().includes(term) ||
                        name.toLowerCase().includes(term) ||
                        vernacular.toLowerCase().includes(term);

                    if (match) {
                        el.style.display = "";
                        visible++;
                        el.querySelector(".lang-code")!.innerHTML =
                            highlightText(code, regex);
                        el.querySelector(".lang-name")!.innerHTML =
                            highlightText(name, regex);
                        const vEl = el.querySelector(".lang-vernacular");
                        if (vEl)
                            vEl.innerHTML = ` - ${highlightText(vernacular, regex)}`;
                    } else {
                        el.style.display = "none";
                    }
                });

                countEl.textContent = (
                    ui.languageCountFiltered || "{visible} of {total} languages"
                )
                    .replace("{visible}", String(visible))
                    .replace("{total}", String(total));
                noResults.style.display = visible === 0 ? "" : "none";
                grid.style.display = visible === 0 ? "none" : "";
            });

            // ── Initialize grid for direct page load (modal closed) ──
            renderGrid(mtLangs);

            // ── Screenshot carousel (mobile) ──
            (() => {
                const row = document.querySelector(
                    ".screenshots-row",
                ) as HTMLElement;
                const cards = [
                    ...document.querySelectorAll<HTMLElement>(
                        ".screenshot-card",
                    ),
                ];
                const steps = document.getElementById("carousel-steps")!;
                const stepBtns = [
                    ...steps.querySelectorAll<HTMLButtonElement>(
                        ".carousel-step",
                    ),
                ];
                if (!row || cards.length === 0) return;

                let current = 0;
                const isMobile = () =>
                    window.matchMedia("(max-width: 768px)").matches;

                function goTo(idx: number) {
                    current = Math.max(0, Math.min(idx, cards.length - 1));
                    cards.forEach((c, i) =>
                        c.classList.toggle("active", i === current),
                    );
                    stepBtns.forEach((b, i) =>
                        b.classList.toggle("active", i === current),
                    );
                    // Center the active card: offset = (container - cardWidth) / 2 - card position
                    const containerW = row.parentElement!.clientWidth;
                    const cardW = containerW * 0.65; // matches CSS width: 65%
                    const offset = (containerW - cardW) / 2 - current * cardW;
                    row.style.transform = `translateX(${offset}px)`;
                }

                stepBtns.forEach((btn) => {
                    btn.addEventListener("click", () =>
                        goTo(Number(btn.dataset.slide)),
                    );
                });

                // Touch swipe support
                let startX = 0;
                let startY = 0;
                let dragging = false;
                row.addEventListener(
                    "touchstart",
                    (e) => {
                        if (!isMobile()) return;
                        startX = e.touches[0].clientX;
                        startY = e.touches[0].clientY;
                        dragging = true;
                    },
                    { passive: true },
                );
                row.addEventListener(
                    "touchend",
                    (e) => {
                        if (!dragging || !isMobile()) return;
                        dragging = false;
                        const dx = e.changedTouches[0].clientX - startX;
                        const dy = e.changedTouches[0].clientY - startY;
                        if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
                            goTo(current + (dx < 0 ? 1 : -1));
                        }
                    },
                    { passive: true },
                );

                // Initialize on mobile
                function init() {
                    if (isMobile()) {
                        goTo(0);
                    } else {
                        row.style.transform = "";
                        cards.forEach((c) => c.classList.remove("active"));
                    }
                }
                init();
                window.addEventListener("resize", init);
            })();
        </script>
    </body>
</html>
