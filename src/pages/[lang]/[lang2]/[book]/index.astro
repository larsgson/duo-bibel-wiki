---
export const prerender = false;

import Layout from "../../../../layouts/Layout.astro";
import langsData from "../../../../data/ALL-langs-compact.json";
import storyLocales from "../../../../generated/story-locales.json";
import { BOOK_MAP, getTemplateImageConfig, getTemplateThemeCSS } from "../../../../utils/chapterData";
import { useTranslations } from "../../../../i18n";

const { lang, lang2, book } = Astro.params;

const bookInfo = BOOK_MAP[book!.toLowerCase()];
if (!bookInfo) {
    return Astro.redirect(`/${lang}/${lang2}`);
}

// ── Validate languages ──
const wt = langsData.canons.nt["with-timecode"] as Record<
    string,
    { n?: string; v?: string }
>;
const awt = langsData.canons.nt["audio-with-timecode"] as Record<
    string,
    { n?: string; v?: string }
>;
const pInfo = wt[lang!] || awt[lang!];
if (!pInfo) return Astro.redirect("/");
const learnCode = lang!;
const learnEnglish = pInfo.n || learnCode;

let sInfo: { n?: string; v?: string } | undefined;
for (const canon of ["nt", "ot"] as const) {
    const canonData = (langsData.canons as any)[canon];
    if (!canonData) continue;
    for (const cat of Object.keys(canonData)) {
        if (canonData[cat][lang2!]) {
            sInfo = canonData[cat][lang2!];
            break;
        }
    }
    if (sInfo) break;
}
if (!sInfo) return Astro.redirect(`/${learnCode}`);
const mtCode = lang2!;
const mtEnglish = sInfo.n || mtCode;
const learnVernacular = pInfo.v || learnEnglish;
const mtVernacular = sInfo.v || mtEnglish;

// ── Build categories data for client ──
const templateData = (storyLocales as any)[bookInfo.img];
if (!templateData) {
    return Astro.redirect(`/${learnCode}/${mtCode}`);
}
const locales = templateData.locales;
const categoriesRaw = templateData.categories;
const locale = locales[learnCode] || locales["eng"] || {};
const engLocale = locales["eng"] || {};

const bookTitle =
    locale.title || locale.longTitle || engLocale.title || bookInfo.img;

const t = useTranslations(mtCode);
const chapterLabel = t("chapter");

const categoriesData: Array<{
    id: string;
    title: string;
    description: string;
    image: string | null;
    stories: Array<{ id: string; title: string; image: string | null }>;
}> = [];

for (const [catId, cat] of Object.entries(categoriesRaw) as [string, any][]) {
    const catLocale = locale[catId] || engLocale[catId] || {};
    const stories = cat.stories.map((s: any) => {
        const storyLocale =
            locale[catId]?.[s.id] || engLocale[catId]?.[s.id] || {};
        return {
            id: s.id,
            title: storyLocale.title || `${chapterLabel} ${s.id}`,
            image: s.image || null,
        };
    });
    categoriesData.push({
        id: catId,
        title: catLocale.title || `Part ${catId}`,
        description: catLocale.description || "",
        image: cat.image || null,
        stories,
    });
}

const categoriesJSON = JSON.stringify(categoriesData);
const imageConfig = getTemplateImageConfig(bookInfo.img);
const imageBaseUrl = imageConfig.baseUrl;
const imagePathPattern = imageConfig.pathPattern;
const imageThumbsResize = imageConfig.thumbsResize;
const imageThumbsPattern = imageConfig.thumbsPattern;
const bookImg = bookInfo.img;
const backHref = `/${learnCode}/${mtCode}`;
const themeCSS = getTemplateThemeCSS(bookInfo.img);
---

<Layout
    title={`${bookTitle} — ${learnEnglish} + ${mtEnglish}`}
    themeCSS={themeCSS}
    learnCode={learnCode}
    learnName={learnVernacular}
    mtCode={mtCode}
    mtName={mtVernacular}
    backHref={backHref}
>
    <style is:global>
        .chapter-picker {
            max-width: 700px;
            margin: 0 auto;
            padding: 1rem 1rem 2rem;
        }
        .chapter-picker-title {
            text-align: center;
            color: var(--text-secondary);
            font-size: 1.3rem;
            font-weight: 600;
            margin: 0 0 1.25rem;
        }

        /* ── Accordion ── */
        .accordion-item {
            margin-bottom: 0.5rem;
            border-radius: 10px;
            overflow: hidden;
            background: var(--bg-surface);
        }
        .accordion-header {
            display: flex;
            align-items: center;
            gap: 12px;
            width: 100%;
            padding: 12px 16px;
            border: none;
            background: none;
            color: var(--text);
            cursor: pointer;
            font: inherit;
            font-size: 0.95rem;
            font-weight: 600;
            text-align: left;
            transition: background 0.2s;
            overflow: hidden;
            box-sizing: border-box;
        }
        .accordion-header:hover {
            background: var(--bg-surface);
        }
        .accordion-thumb {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            object-fit: cover;
            flex-shrink: 0;
        }
        .accordion-info {
            flex: 1;
            min-width: 0;
            overflow: hidden;
        }
        .accordion-title {
            display: block;
        }
        .accordion-desc {
            display: block;
            font-size: 0.72rem;
            font-weight: 400;
            color: var(--text-secondary);
            margin-top: 2px;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }
        .accordion-chevron {
            font-size: 1.1rem;
            color: var(--chevron);
            transition: transform 0.25s ease;
            flex-shrink: 0;
        }
        .accordion-item.open .accordion-chevron {
            transform: rotate(90deg);
        }

        .accordion-body {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.35s ease;
        }
        .accordion-item.open .accordion-body {
            max-height: 2000px;
        }
        .accordion-body-inner {
            padding: 0 12px 16px;
        }

        /* ── Chapter grid ── */
        .chapter-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 12px;
        }
        @media (max-width: 500px) {
            .chapter-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 8px;
            }
        }
        @media (max-width: 360px) {
            .chapter-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 8px;
            }
        }
        .chapter-card {
            display: flex;
            flex-direction: column;
            border-radius: 8px;
            overflow: hidden;
            background: var(--bg-surface);
            text-decoration: none;
            color: inherit;
            transition:
                transform 0.15s,
                box-shadow 0.15s;
        }
        .chapter-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px var(--shadow-strong);
        }
        .chapter-card-img {
            width: 100%;
            aspect-ratio: 3 / 2;
            object-fit: cover;
            display: block;
        }
        .chapter-card-info {
            padding: 8px 10px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .chapter-card-num {
            font-size: 0.7rem;
            color: var(--accent);
            font-weight: 600;
        }
        .chapter-card-title {
            font-size: 0.78rem;
            color: var(--text);
            line-height: 1.3;
        }

        /* ── Chapter progress badge ── */
        .chapter-card { position: relative; }
        .ch-progress {
            position: absolute;
            top: 6px;
            right: 6px;
        }
        .ch-progress-counter {
            background: var(--overlay);
            color: var(--success-bright);
            font-size: 0.65rem;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 10px;
            white-space: nowrap;
            font-family: monospace;
        }
        .ch-progress-check {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--success-bright);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .ch-progress-check svg {
            width: 14px;
            height: 14px;
        }
    </style>

    <div class="chapter-picker">
        <h1 class="chapter-picker-title" id="book-title"></h1>
        <div id="accordion-container"></div>
    </div>

    <script data-astro-rerun define:vars={{ categoriesJSON, bookTitle, book, chapterLabel, imageBaseUrl, imagePathPattern, imageThumbsResize, imageThumbsPattern, learnCode, mtCode, bookImg }}>
        const categories = JSON.parse(categoriesJSON);
        const IMG_BASE = imageBaseUrl ? imageBaseUrl + "/" : "";
        const bookKey = book.toLowerCase();

        // ── Determine which category to open ──
        let openCatId = categories[0]?.id || "01";
        try {
            const lastCat = localStorage.getItem(`lastVisitedCategory_${bookKey}`);
            if (lastCat) {
                openCatId = lastCat;
            }
        } catch (e) {
            /* localStorage unavailable */
        }

        function resolveImageUrl(filename) {
            if (!filename) return "";
            if (filename.startsWith("http")) return filename;
            // Apply path pattern (e.g. "{book}/{filename}" where book = first 2 chars)
            const resolved = imagePathPattern
                .replace("{filename}", filename)
                .replace("{book}", filename.substring(0, 2));
            return `${IMG_BASE}${resolved}`;
        }

        function imgProxy(url, w) {
            if (!url) return url;
            // Prefer pre-sized thumbs when template provides a thumbs pattern
            if (imageThumbsPattern && IMG_BASE) {
                const filename = url.startsWith("http") ? url.split("/").pop() : url;
                const thumb = imageThumbsPattern
                    .replace("{filename}", filename)
                    .replace("{book}", filename.substring(0, 2));
                return `${IMG_BASE}${thumb}`;
            }
            const full = resolveImageUrl(url);
            // Fall back to Netlify Image CDN resize
            if (imageThumbsResize === "netlify") {
                return `/.netlify/images?url=${encodeURIComponent(full)}&w=${w}`;
            }
            return full;
        }

        // ── Render ──
        document.getElementById("book-title").textContent = bookTitle;

        const container = document.getElementById("accordion-container");
        let html = "";
        for (const cat of categories) {
            const isOpen = cat.id === openCatId ? " open" : "";
            const imgTag = cat.image
                ? `<img class="accordion-thumb" src="${imgProxy(cat.image, 88)}" alt="">`
                : "";

            let cardsHTML = "";
            for (const story of cat.stories) {
                const imgSrc = story.image || cat.image || "";
                cardsHTML += `<a class="chapter-card" href="./${cat.id}/${story.id}/" data-cat="${cat.id}" data-story="${story.id}">
                    ${imgSrc ? `<img class="chapter-card-img" src="${imgProxy(imgSrc, 300)}" alt="" loading="lazy">` : ""}
                    <div class="chapter-card-info">
                        <span class="chapter-card-num">${chapterLabel} ${parseInt(story.id, 10)}</span>
                        <span class="chapter-card-title">${story.title}</span>
                    </div>
                </a>`;
            }

            html += `<div class="accordion-item${isOpen}" data-cat="${cat.id}">
                <button class="accordion-header">
                    ${imgTag}
                    <div class="accordion-info">
                        <span class="accordion-title">${cat.title}</span>
                        <span class="accordion-desc">${cat.description}</span>
                    </div>
                    <span class="accordion-chevron">&#x25B8;</span>
                </button>
                <div class="accordion-body">
                    <div class="accordion-body-inner">
                        <div class="chapter-grid">${cardsHTML}</div>
                    </div>
                </div>
            </div>`;
        }
        container.innerHTML = html;

        // ── Accordion behavior ──
        container.addEventListener("click", (e) => {
            const header = e.target.closest(".accordion-header");
            if (!header) return;
            const item = header.closest(".accordion-item");
            const wasOpen = item.classList.contains("open");

            // Close all
            container
                .querySelectorAll(".accordion-item.open")
                .forEach((el) => el.classList.remove("open"));

            // Open clicked (unless it was already open — then it stays closed)
            if (!wasOpen) {
                item.classList.add("open");
            }
        });

        // ── Achievement progress badges on chapter cards ──
        const EX_KEY_MAP = { "listen-fill": "f", "listen-order": "o", "sentence-builder": "s" };
        const CHECK_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';

        function getActiveExKey() {
            var ex = localStorage.getItem("activeExercise") || "listen-fill";
            return EX_KEY_MAP[ex] || "f";
        }

        function renderProgressBadges() {
            var exKey = getActiveExKey();
            container.querySelectorAll(".chapter-card").forEach(function(card) {
                var catId = card.getAttribute("data-cat");
                var storyId = card.getAttribute("data-story");
                if (!catId || !storyId) return;
                var storageKey = "a:" + learnCode + "/" + mtCode + "/" + bookImg + "/" + catId + "/" + storyId;
                var obj;
                try { obj = JSON.parse(localStorage.getItem(storageKey) || "{}"); } catch(e) { return; }
                var arr = obj[exKey] || [];
                var total = obj.t || 0;
                if (arr.length === 0 || total === 0) return;

                var existing = card.querySelector(".ch-progress");
                if (existing) existing.remove();

                var badge = document.createElement("div");
                badge.className = "ch-progress";

                if (arr.length >= total) {
                    badge.innerHTML = '<div class="ch-progress-check">' + CHECK_SVG + '</div>';
                } else {
                    badge.innerHTML = '<span class="ch-progress-counter">' + arr.length + '/' + total + '</span>';
                }
                card.appendChild(badge);
            });
        }
        renderProgressBadges();
    </script>
</Layout>
