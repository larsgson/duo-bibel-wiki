            },
            {
                id: "sentence-builder",
                localeKey: "sentenceBuilder",
                icon: "puzzle",
                showInTabs: false,
                tabOrder: 4,
            },
        ];
        const ICON_SVGS = {
            "ear-reveal":
                '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12c0-4 3-7 6-7s6 3 6 7"/><path d="M18 12c0 3-1.5 5-3 6.5S12 21 12 21"/><circle cx="12" cy="14" r="1.5" fill="currentColor" stroke="none"/><path d="M1 12s4-6 8-6" opacity="0.5"/></svg>',
            "ear-sort":
                '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12c0-4 3-7 6-7s6 3 6 7"/><path d="M18 12c0 3-1.5 5-3 6.5S12 21 12 21"/><path d="M8 14h8M9 17h6M10 11h4" opacity="0.7"/></svg>',
            "ear-blank":
                '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12c0-4 3-7 6-7s6 3 6 7"/><path d="M18 12c0 3-1.5 5-3 6.5S12 21 12 21"/><path d="M8 15h3M13 15h3" stroke-width="2.5" opacity="0.6"/></svg>',
            "ear-check":
                '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12c0-4 3-7 6-7s6 3 6 7"/><path d="M18 12c0 3-1.5 5-3 6.5S12 21 12 21"/><path d="M8 13l2.5 2.5L16 10" stroke-width="2"/></svg>',
            puzzle: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h3a2 2 0 0 0 0-4h0a2 2 0 0 0 0 4h3v3a2 2 0 0 1 4 0v0a2 2 0 0 1-4 0v3H7a2 2 0 0 0 0 4h0a2 2 0 0 0 0-4H4V7z"/><path d="M14 14h3a2 2 0 0 1 0 4h0a2 2 0 0 1 0-4h3V7h-3a2 2 0 0 0 0-4h0a2 2 0 0 0 0 4h-3v7z"/></svg>',
            more: '<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>',
        };

        // ══════════════════════════════════════════
        // STATE
        // Filter exercises when mt has no text
        if (!mtHasText) {
            // Keep only the "listen" link (audio-only mode)
            const listenOnly = EXERCISES.filter((e) => e.id === "listen");
            EXERCISES.length = 0;
            EXERCISES.push(...listenOnly);
        }

        // ══════════════════════════════════════════
        let isPlaying = false;
        let peekTimer = null;
        const VALID_EXERCISES = new Set(EXERCISES.map((e) => e.id));
        const hashExercise = location.hash.slice(1);
        const savedExercise = localStorage.getItem("activeExercise");
        let activeExercise =
            hashExercise && VALID_EXERCISES.has(hashExercise)
                ? hashExercise
                : savedExercise && VALID_EXERCISES.has(savedExercise)
                  ? savedExercise
                  : mtHasText
                    ? "listen-fill"
                    : "listen";
        let exState = {};
        function getStore() { return window.__audioStore; }

        // Current verse data (set by loadVerse)
        let VERSE = {
            learnText: "",
            mtText: "",
            learnAudioUrl: "",
            mtAudioUrl: "",
            startTime: 0,
            endTime: 0,
            mtStartTime: 0,
            mtEndTime: 0,
            imageUrl: "",
            reference: "",
            versePosition: 0,
            totalVerses: learnSteps.length,
            wordTimings: null,
        };
        let currentIdx = 0;

        // Persist state for landing page resume
        function saveLastState() {
            const entry = {
                lang: learnCode,
                lang2: mtCode,
                url: window.location.pathname + window.location.hash,
                imageUrl: VERSE.imageUrl,
                reference: VERSE.reference,
                exercise: activeExercise,
                ts: Date.now(),
            };
            localStorage.setItem("lastState", JSON.stringify(entry));

            // Maintain history (max 10, dedupe by story path — strip hash/verse)
            try {
                const hist = JSON.parse(localStorage.getItem("studyHistory") || "[]");
                const storyPath = entry.url.replace(/#.*$/, "");
                const filtered = hist.filter(function(h) {
                    return h.url.replace(/#.*$/, "") !== storyPath;
                });
                filtered.unshift(entry);
                localStorage.setItem("studyHistory", JSON.stringify(filtered.slice(0, 10)));
            } catch (e) {}
        }

        // DOM
        const imageContainer = document.getElementById("image-container");
        const verseImage = document.getElementById("verse-image");
        const playIcon = document.getElementById("play-icon");
        const navPrev = document.getElementById("nav-prev");
        const navNext = document.getElementById("nav-next");
        const verseReference = document.getElementById("verse-reference");
        const peekBtn = document.getElementById("peek-btn");
        const peekOverlay = document.getElementById("peek-overlay");
        const peekText = document.getElementById("peek-text");
        const secondaryTextEl = document.getElementById("secondary-text");
        const secPlayBtn = document.getElementById("secondary-play-btn");
        const exerciseArea = document.getElementById("exercise-area");
        const verseCounter = document.getElementById("verse-counter");
        const exerciseSelector = document.getElementById("exercise-selector");
        const exerciseSelectorLabel = document.getElementById("exercise-selector-label");
        const actionSheetOverlay = document.getElementById("action-sheet-overlay");
        const actionSheetItems = document.getElementById("action-sheet-items");

        // ══════════════════════════════════════════
        // VERSE LOADING (hash-based)
        // ══════════════════════════════════════════
        function getVerseFromHash() {
            const hash = window.location.hash.slice(1);
            const num = parseInt(hash, 10);
            if (isNaN(num) || num < 1)
                return learnSteps[0]?.verseStart || 1;
            return num;
        }

        async function loadVerse(verseNum) {
            await ensureChapterData();

            const idx = learnSteps.findIndex(
                (e) => e.verseStart === verseNum,
            );
            if (idx === -1) {
                // Try finding the parent range that contains this verse
                const rangeIdx = learnSteps.findIndex(
                    (e) => verseNum >= e.verseStart && verseNum <= e.verseEnd,
                );
                if (rangeIdx !== -1) {
                    window.location.hash = "#" + learnSteps[rangeIdx].verseStart;
                } else if (learnSteps.length > 0) {
                    window.location.hash = "#" + learnSteps[0].verseStart;
                }
                return;
            }

            currentIdx = idx;
            const entry = learnSteps[idx];
            const prevEntry = idx > 0 ? learnSteps[idx - 1] : null;
            const nextEntry =
                idx < learnSteps.length - 1 ? learnSteps[idx + 1] : null;

            // Get text — single verse
            const learnText = getTextForVerse(cachedLearnTexts, entry);
            const mtText = getTextForVerse(cachedMtTexts, entry);

            // Image — use imageRef, falling back to nearest earlier step's image,
            // or as last resort the nearest later step's image
            let imageUrl = imgProxy(
                findBestImage(CHAPTER.chapterNum, entry.verseStart, entry.imageRef),
                600,
            );
            if (!imageUrl) {
                // Search earlier steps
                for (let p = idx - 1; p >= 0; p--) {
                    var pimg = findBestImage(CHAPTER.chapterNum, learnSteps[p].verseStart, learnSteps[p].imageRef);
                    if (pimg) { imageUrl = imgProxy(pimg, 600); break; }
                }
            }
            if (!imageUrl) {
                // Last resort: search later steps
                for (let n = idx + 1; n < learnSteps.length; n++) {
                    var nimg = findBestImage(CHAPTER.chapterNum, learnSteps[n].verseStart, learnSteps[n].imageRef);
                    if (nimg) { imageUrl = imgProxy(nimg, 600); break; }
                }
            }

            // MT timing
            let mtStartTime = entry.startTime;
            let mtEndTime = entry.endTime;
            const secTiming = CHAPTER.mtChapterTiming;
            if (secTiming) {
                for (const [ref, times] of Object.entries(secTiming)) {
                    const colonIdx = ref.indexOf(":");
                    const vs = ref.substring(colonIdx + 1);
                    const parts = vs.split("-");
                    const vs1 = parseInt(parts[0], 10);
                    const vs2 =
                        parts.length > 1
                            ? parseInt(parts[parts.length - 1], 10)
                            : vs1;
                    if (verseNum >= vs1 && verseNum <= vs2) {
                        mtStartTime = times[0];
                        mtEndTime = times[times.length - 1];
                        break;
                    }
                }
            }

            // Reference — derive from the verse ref (e.g. "GEN3:1" → "GEN 3:1")
            const refMatch = entry.ref.match(/^([A-Z0-9]+?)(\d+:\d+(?:-\d+)?)$/);
            const reference = refMatch ? `${refMatch[1]} ${refMatch[2]}` : entry.ref;

            // Word-level timing for this verse (keyed by verse number)
            const wt = CHAPTER.learnWordTiming;
            let wordTimings = null;
            if (wt) {
                wordTimings = wt[String(entry.verseStart)] || null;
            }

            // Update VERSE state
            VERSE = {
                learnText,
                mtText,
                learnAudioUrl: resolveAudioUrl(cachedLearnAudioUrl, entry.ref),
                mtAudioUrl: resolveAudioUrl(cachedMtAudioUrl, entry.ref),
                startTime: entry.startTime,
                endTime: entry.endTime,
                mtStartTime,
                mtEndTime,
                imageUrl,
                reference,
                versePosition: idx + 1,
                totalVerses: learnSteps.length,
                wordTimings,
            };

            // Preload AudioBuffer for verse and word-level playback
            if (VERSE.learnAudioUrl) {
                const store = getStore();
                if (store) store.preloadBuffer(VERSE.learnAudioUrl, "learn");
            }

            // Stop any playing audio
            if (isPlaying) {
                const store = getStore();
                if (store) store.stopExerciseAudio();
                isPlaying = false;
                imageContainer.classList.remove("playing");
                playIcon.innerHTML = "&#9654;";
            }
            if (mtPlaying) stopSecondary();

            // Update DOM
            verseImage.src = imageUrl;
            verseImage.alt = reference;
            verseReference.textContent = reference;
            peekText.textContent = learnText || "Text not available";
            if (mtHasText) {
                secondaryTextEl.textContent =
                    mtText || t("textNotAvailable");
            } else {
                secondaryTextEl.textContent = "";
            }
            verseCounter.textContent = `${idx + 1} / ${learnSteps.length}`;

            // Nav arrows — skip completed verses
            const prevIncIdx = findPrevIncomplete(idx);
            if (prevIncIdx >= 0) {
                navPrev.dataset.verse = learnSteps[prevIncIdx].verseStart;
                navPrev.classList.remove("hidden");
            } else {
                navPrev.classList.add("hidden");
            }
            const nextIncIdx = findNextIncomplete(idx);
            if (nextIncIdx >= 0) {
                navNext.dataset.verse = learnSteps[nextIncIdx].verseStart;
                navNext.classList.remove("hidden");
            } else {
                navNext.classList.add("hidden");
            }

            // MT play button visibility
            if (cachedMtAudioUrl) {
                secPlayBtn.style.display = "";
            } else {
                secPlayBtn.style.display = "none";
            }

            // Reset exercise state and render
            exState = {};
            renderExercise();

            // Save state
            saveLastState();

            // Prefetch adjacent images (use parent entry ref for image lookup)
            if (prevEntry) {
                const img = new Image();
                img.src = imgProxy(
                    findBestImage(CHAPTER.chapterNum, prevEntry.verseStart, prevEntry.imageRef),
                    600,
                );
            }
            if (nextEntry) {
                const img = new Image();
                img.src = imgProxy(
                    findBestImage(CHAPTER.chapterNum, nextEntry.verseStart, nextEntry.imageRef),
                    600,
                );
            }
        }

        // ══════════════════════════════════════════
        // EXERCISE SELECTOR (action sheet)
        // ══════════════════════════════════════════
        function getExerciseLabel(ex) {
            return t(ex.localeKey) || ex.id;
        }

        function updateSelectorLabel() {
            const ex = EXERCISES.find(e => e.id === activeExercise);
            exerciseSelectorLabel.textContent = ex ? getExerciseLabel(ex) : activeExercise;
        }

        function renderActionSheet() {
            const sorted = [...EXERCISES].sort((a, b) => a.tabOrder - b.tabOrder);
            actionSheetItems.innerHTML = sorted.map(ex => {
                if (ex.href) {
                    return `<a class="action-sheet-item" href="${ex.href}">
                        ${ICON_SVGS[ex.icon]}
                        <span>${getExerciseLabel(ex)}</span>
                    </a>`;
                }
                return `<button class="action-sheet-item${activeExercise === ex.id ? ' active' : ''}" data-exercise="${ex.id}">
                    ${ICON_SVGS[ex.icon]}
                    <span>${getExerciseLabel(ex)}</span>
                </button>`;
            }).join('');
        }

        exerciseSelector.addEventListener("click", () => {
            renderActionSheet();
            actionSheetOverlay.classList.remove("hidden");
        });

        actionSheetOverlay.addEventListener("click", (e) => {
            if (e.target === actionSheetOverlay) {
                actionSheetOverlay.classList.add("hidden");
                return;
            }
            const btn = e.target.closest("[data-exercise]");
            if (btn) {
                const id = btn.dataset.exercise;
                if (id !== activeExercise) {
                    activeExercise = id;
                    localStorage.setItem("activeExercise", id);
                    saveLastState();
                    exState = {};
                    renderExercise();
                }
                updateSelectorLabel();
                actionSheetOverlay.classList.add("hidden");
            }
        });

        // ══════════════════════════════════════════
        // EXERCISE RENDERING
        // ══════════════════════════════════════════
        function getPrimaryWords() {
            return tokenizeText(VERSE.learnText || "");
        }

        // ── Word-level audio helpers ──
        function hasWordAudio(wordIdx) {
            const wt = VERSE.wordTimings;
            if (!wt || wordIdx < 0 || wordIdx >= wt.length) return false;
            return wt[wordIdx] !== null;
        }

        function stopWordAudio() {
            const store = getStore();
            if (store) store.stopWordAudio();
            document.querySelectorAll(".word-audio-playing").forEach(el => el.classList.remove("word-audio-playing"));
        }

        function playWordAudio(wordIdx) {
            const wt = VERSE.wordTimings;
            if (!wt || !VERSE.learnAudioUrl) return;
            const store = getStore();
            if (!store) return;

            // Stop any current word/verse playback
            stopWordAudio();
            if (isPlaying) {
                store.stopExerciseAudio();
                isPlaying = false;
                imageContainer.classList.remove("playing");
                playIcon.innerHTML = "&#9654;";
            }

            store.playWordAudio(wt, wordIdx, VERSE.learnAudioUrl, VERSE.endTime, () => {
                document.querySelectorAll(".word-audio-playing").forEach(el => el.classList.remove("word-audio-playing"));
            });
        }

        function wordAudioAttr(wordIdx) {
            if (!hasWordAudio(wordIdx)) return "";
            return ` data-word-audio="${wordIdx}"`;
        }

        function wordAudioClass(wordIdx) {
            return hasWordAudio(wordIdx) ? " has-word-audio" : "";
        }

        // ── Achievement tracking ──
        const EX_KEY = { "listen-fill": "f", "listen-order": "o", "sentence-builder": "s" };
        const achStorageKey = "a:" + learnCode + "/" + mtCode + "/" + CHAPTER.bookImg + "/" + categoryId + "/" + CHAPTER.chapterNum;

        function getCompletedSet() {
            try {
                var obj = JSON.parse(localStorage.getItem(achStorageKey) || "{}");
                var k = EX_KEY[activeExercise] || "f";
                return new Set(obj[k] || []);
            } catch (e) { return new Set(); }
        }

        function isStepComplete(stepIdx) {
            var done = getCompletedSet();
            return done.has(learnSteps[stepIdx]?.verseStart);
        }

        function findNextIncomplete(fromIdx) {
            for (var i = fromIdx + 1; i < learnSteps.length; i++) {
                if (!isStepComplete(i)) return i;
            }
            return -1;
        }

        function findPrevIncomplete(fromIdx) {
            for (var i = fromIdx - 1; i >= 0; i--) {
                if (!isStepComplete(i)) return i;
            }
            return -1;
        }

        function recordAchievement() {
            var k = EX_KEY[activeExercise];
            if (!k) return;
            var v = learnSteps[currentIdx]?.verseStart;
            if (!v) return;
            try {
                var obj = JSON.parse(localStorage.getItem(achStorageKey) || "{}");
                obj.t = learnSteps.length;
                var arr = obj[k] || [];
                if (arr.indexOf(v) === -1) {
                    arr.push(v);
                    arr.sort(function(a, b) { return a - b; });
                    obj[k] = arr;
                    localStorage.setItem(achStorageKey, JSON.stringify(obj));
                }
            } catch (e) {}
        }

        function completionHTML() {
            recordAchievement();
            const hasNext = currentIdx < learnSteps.length - 1;
            const btnHTML = hasNext
                ? `<button class="exercise-continue-btn" data-action="continue-next">${t("continue")} &rarr;</button>`
                : "";
            return `<div class="exercise-complete-bar"><button class="exercise-reset-btn" data-action="exercise-reset" title="Try again">&#8635;</button><span class="exercise-complete-text">${t("completed")}</span>${btnHTML}<button class="exercise-dismiss-btn" data-action="exercise-reset" title="Dismiss">&times;</button></div>`;
        }

        function renderExercise() {
            if (!exerciseArea) return;
            if (!mtHasText) {
                exerciseArea.innerHTML = `<div class="no-text-message">${t("audioOnly")}</div>`;
                return;
            }
            if (!VERSE.learnText) {
                exerciseArea.innerHTML = `<div class="no-text-message">${t("textNotAvailable")}</div>`;
                return;
            }
            switch (activeExercise) {
                case "listen-reveal":
                    renderListenReveal();
                    break;
                case "listen-order":
                    renderListenOrder();
                    break;
                case "listen-fill":
                    renderListenFill();
                    break;
                case "sentence-builder":
                    renderSentenceBuilder();
                    break;
                default:
                    exerciseArea.innerHTML = "";
            }
        }

        function renderListenReveal() {
            const words = getPrimaryWords();
            if (!exState.revealedSet) exState.revealedSet = new Set();
            const rev = exState.revealedSet;
            const allRevealed = rev.size >= words.length;
            const wordsHTML = words
                .map((w, i) => {
                    if (rev.has(i))
                        return `<span class="listen-reveal-word revealed${wordAudioClass(i)}" data-idx="${i}"${wordAudioAttr(i)}>${w}</span>`;
                    const placeholder = CJK_REGEX.test(w)
                        ? "\u3000".repeat(Math.max(w.length, 2))
                        : "\u00A0".repeat(Math.max(w.length, 3));
                    return `<span class="listen-reveal-word hidden${wordAudioClass(i)}" data-idx="${i}"${wordAudioAttr(i)}>${placeholder}</span>`;
                })
                .join("");
            const eyeSvg = allRevealed
                ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>'
                : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>';
            exerciseArea.innerHTML = `<div class="listen-reveal">
                <div class="listen-reveal-words"${learnRtlAttr}>${wordsHTML}</div>
                <div class="listen-reveal-actions">
                    <button class="listen-reveal-eye-btn" data-action="toggle-all" title="${allRevealed ? t("hideAll") : t("revealAll")}">${eyeSvg}</button>
                </div></div>`;
        }

        function renderListenOrder() {
            const words = getPrimaryWords();
            const prefillCount = Math.floor(words.length / 2);
            if (!exState.filledWords) {
                exState.filledWords = [];
                exState.gapIndices = Array.from(
                    { length: words.length - prefillCount },
                    (_, i) => prefillCount + i,
                );
                exState.tiles = shuffleArray(
                    exState.gapIndices.map((i) => ({ id: i, text: words[i] })),
                );
            }
            const { filledWords, gapIndices, tiles } = exState;
            const usedIds = new Set(filledWords.map((fw) => fw.id));
            const remainingTiles = tiles.filter(
                (tile) => !usedIds.has(tile.id),
            );
            const allCorrect =
                filledWords.length === gapIndices.length &&
                filledWords.every((fw, n) =>
                    wordsMatch(fw.text, words[gapIndices[n]]),
                );
            const lastIdx = filledWords.length - 1;
            const lastIsWrong =
                lastIdx >= 0 &&
                !wordsMatch(
                    filledWords[lastIdx].text,
                    words[gapIndices[lastIdx]],
                );
            // Build one continuous verse line
            const usesSpaces = textUsesSpaces(VERSE.learnText || "");
            const wordJoiner = usesSpaces ? " " : "";
            const verseHTML = words
                .map((w, i) => {
                    if (i < prefillCount) {
                        return `<span class="listen-order-given-word${wordAudioClass(i)}"${wordAudioAttr(i)}>${w}</span>`;
                    }
                    const gapPos = gapIndices.indexOf(i);
                    if (gapPos < filledWords.length) {
                        const fw = filledWords[gapPos];
                        const isCorrect = wordsMatch(fw.text, words[i]);
                        const isLast = gapPos === lastIdx;
                        const isRemovable = isLast && !isCorrect;
                        let cls = "listen-order-placed";
                        if (isCorrect) cls += " correct";
                        else cls += " incorrect";
                        return `<span class="${cls}${wordAudioClass(i)}" ${isRemovable ? 'data-action="remove-last"' : ""}${wordAudioAttr(i)}>${fw.text}</span>`;
                    }
                    return `<span class="listen-order-slot">____</span>`;
                })
                .join(wordJoiner);
            // When last word is wrong, show it back in the bank as available
            const effectiveTiles = lastIsWrong
                ? tiles.filter(
                      (tile) =>
                          !usedIds.has(tile.id) ||
                          tile.id === filledWords[lastIdx].id,
                  )
                : remainingTiles;
            const bankHTML = effectiveTiles
                .map(
                    (tile) => {
                        const wa = hasWordAudio(tile.id);
                        return `<button class="word-tile${wa ? " has-word-audio" : ""}" data-action="place-word" data-id="${tile.id}"${wa ? ` data-word-audio="${tile.id}"` : ""}><span class="word-tile-text">${tile.text}</span>${wa ? '<span class="word-tile-place" data-action="place-word">&#9650;</span>' : ""}</button>`;
                    },
                )
                .join("");
            const headerHTML = allCorrect
                ? completionHTML()
                : `<p class="listen-order-instruction">${t("orderWords")}</p>`;
            exerciseArea.innerHTML = `<div class="listen-order">
                ${headerHTML}
                <div class="listen-order-verse"${learnRtlAttr}>${verseHTML}</div>
                <div class="listen-order-bank"${learnRtlAttr}>${bankHTML}</div></div>`;
        }

        function getAdjacentVerseWords() {
            const words = [];
            const nearby = [currentIdx - 1, currentIdx + 1];
            for (const ni of nearby) {
                if (ni >= 0 && ni < learnSteps.length && cachedLearnTexts) {
                    const text = getTextForVerse(
                        cachedLearnTexts,
                        learnSteps[ni],
                    );
                    if (text) words.push(...tokenizeText(text));
                }
            }
            return words;
        }

        function renderListenFill() {
            const words = getPrimaryWords();
            if (!exState.filledWords) {
                const gaps = pickGapWords(words, 2).sort((a, b) => a - b);
                const correctWords = gaps.map((i) => words[i]);
                const seen = new Set(correctWords.map(normalizeWord));
                const isCJK = CJK_REGEX.test(words.join(""));
                const minDistractorLen = isCJK ? 0 : 2;
                // Collect distractor words from current verse
                const otherWords = words
                    .filter((_, i) => !gaps.includes(i))
                    .filter((w) => {
                        const n = normalizeWord(w);
                        if (n.length <= minDistractorLen || seen.has(n))
                            return false;
                        seen.add(n);
                        return true;
                    });
                // If not enough distractors, pull from adjacent verses
                if (otherWords.length < 2) {
                    const adjWords = getAdjacentVerseWords();
                    for (const w of adjWords) {
                        const n = normalizeWord(w);
                        if (n.length <= minDistractorLen || seen.has(n))
                            continue;
                        seen.add(n);
                        otherWords.push(w);
                        if (otherWords.length >= 4) break;
                    }
                }
                exState.gapIndices = gaps;
                exState.bankWords = shuffleArray([
                    ...correctWords,
                    ...shuffleArray(otherWords).slice(0, 2),
                ]);
                exState.filledWords = [];
            }
            const { gapIndices, bankWords, filledWords } = exState;
            const allCorrect =
                filledWords.length === gapIndices.length &&
                filledWords.every((fw, n) =>
                    wordsMatch(fw.text, words[gapIndices[n]]),
                );
            const lastIdx = filledWords.length - 1;
            const lastIsWrong =
                lastIdx >= 0 &&
                !wordsMatch(
                    filledWords[lastIdx].text,
                    words[gapIndices[lastIdx]],
                );
            const verseHTML = words
                .map((w, i) => {
                    if (gapIndices.includes(i)) {
                        const gapPos = gapIndices.indexOf(i);
                        const filled = filledWords[gapPos];
                        if (filled) {
                            const isCorrect = wordsMatch(filled.text, words[i]);
                            const isLast = gapPos === lastIdx;
                            const isRemovable = isLast && !isCorrect;
                            let cls = "listen-fill-blank filled";
                            if (isCorrect) cls += " correct";
                            else cls += " incorrect";
                            return `<span class="${cls}${wordAudioClass(i)}" ${isRemovable ? 'data-action="remove-last" style="cursor:pointer"' : ""}${wordAudioAttr(i)}>${filled.text}</span>`;
                        }
                        return `<span class="listen-fill-blank">____</span>`;
                    }
                    return `<span class="listen-fill-word${wordAudioClass(i)}"${wordAudioAttr(i)}>${w}</span>`;
                })
                .join("");
            // When last word is wrong, exclude it from used so it's available again
            const effectiveUsed = lastIsWrong
                ? filledWords.slice(0, -1).map((fw) => fw.text)
                : filledWords.map((fw) => fw.text);
            // Map bank words to their original word index for audio lookup
            function findWordIdx(bankWord) {
                const idx = words.findIndex((w) => w === bankWord);
                return idx >= 0 ? idx : -1;
            }
            const bankHTML = bankWords
                .map((w) => {
                    const isUsed = effectiveUsed.includes(w);
                    const wi = findWordIdx(w);
                    const wa = wi >= 0 && hasWordAudio(wi);
                    return `<button class="word-tile${isUsed ? " used" : ""}${wa ? " has-word-audio" : ""}" data-action="fill-bank" data-word="${w}" ${isUsed ? "disabled" : ""}${wa ? ` data-word-audio="${wi}"` : ""}><span class="word-tile-text">${w}</span>${wa ? '<span class="word-tile-place" data-action="fill-bank">&#9650;</span>' : ""}</button>`;
                })
                .join("");
            const headerHTML = allCorrect
                ? completionHTML()
                : `<p class="listen-fill-instruction">${t("fillBlanks")}</p>`;
            exerciseArea.innerHTML = `<div class="listen-fill-gap">
                ${headerHTML}
                <div class="listen-fill-verse"${learnRtlAttr}>${verseHTML}</div>
                <div class="listen-fill-bank"${learnRtlAttr}>${bankHTML}</div></div>`;
        }

        function renderSentenceBuilder() {
            const words = getPrimaryWords();
            if (!exState.sbTiles) {
                exState.sbTiles = shuffleArray(
                    words.map((w, i) => ({ id: i, text: w })),
                );
                exState.sbPlacedIds = [];
                exState.sbChecked = false;
                exState.sbResult = null;
                exState.sbHintVisible = false;
            }
            const { sbTiles, sbPlacedIds, sbChecked, sbResult, sbHintVisible } =
                exState;
            const remainingTiles = sbTiles.filter(
                (tile) => !sbPlacedIds.includes(tile.id),
            );
            const allPlaced = sbPlacedIds.length === words.length;
            const allCorrect =
                sbChecked &&
                sbResult &&
                sbResult.every((r) => r.status === "correct");
            const hintHTML = sbHintVisible
                ? `<div class="sentence-builder-hint-overlay" data-action="sb-hide-hint"><p class="sentence-builder-hint-text">${VERSE.mtText}</p></div>`
                : "";
            let answerHTML = "";
            if (!sbChecked) {
                answerHTML =
                    sbPlacedIds.length === 0
                        ? '<span class="sentence-builder-placeholder">...</span>'
                        : sbPlacedIds
                              .map(
                                  (id) => {
                                      const wa = hasWordAudio(id);
                                      return `<button class="word-tile placed${wa ? " has-word-audio" : ""}" data-action="sb-remove" data-id="${id}"${wa ? ` data-word-audio="${id}"` : ""}><span class="word-tile-text">${words[id]}</span>${wa ? '<span class="word-tile-place" data-action="sb-remove">&#9660;</span>' : ""}</button>`;
                                  },
                              )
                              .join("");
            } else if (sbResult) {
                answerHTML = sbResult
                    .map((entry) => {
                        let cls = "word-tile placed";
                        if (entry.status === "correct") cls += " word-correct";
                        else if (entry.status === "displaced")
                            cls += " word-displaced";
                        else cls += " word-wrong";
                        const wa = hasWordAudio(entry.id);
                        return `<span class="${cls}${wa ? " has-word-audio" : ""}"${wa ? ` data-word-audio="${entry.id}"` : ""}>${entry.word}</span>`;
                    })
                    .join("");
            }
            let bankHTML = !sbChecked
                ? `<div class="sentence-builder-bank"${learnRtlAttr}>${remainingTiles
                      .map(
                          (tile) => {
                              const wa = hasWordAudio(tile.id);
                              return `<button class="word-tile${wa ? " has-word-audio" : ""}" data-action="sb-place" data-id="${tile.id}"${wa ? ` data-word-audio="${tile.id}"` : ""}><span class="word-tile-text">${tile.text}</span>${wa ? '<span class="word-tile-place" data-action="sb-place">&#9650;</span>' : ""}</button>`;
                          },
                      )
                      .join("")}</div>`
                : "";
            let actionsHTML = "";
            if (allPlaced && !sbChecked)
                actionsHTML = `<button class="sentence-builder-check-btn" data-action="sb-check">${t("check")}</button>`;
            else if (allCorrect) actionsHTML = "";
            else if (sbChecked && !allCorrect)
                actionsHTML = `<button class="sentence-builder-reset-btn" data-action="sb-reset">\u21BB</button>`;
            const headerHTML = allCorrect
                ? completionHTML()
                : `<div class="sentence-builder-hint-wrapper">
                    <p class="sentence-builder-instruction">${t("buildSentence")}
                        <button class="sentence-builder-hint-btn" data-action="sb-hint">?</button></p>${hintHTML}
                </div>`;
            exerciseArea.innerHTML = `<div class="sentence-builder">
                ${headerHTML}
                <div class="sentence-builder-answer"${learnRtlAttr}>${answerHTML}</div>${bankHTML}
                <div class="sentence-builder-actions">${actionsHTML}</div></div>`;
        }

        // ══════════════════════════════════════════
        // SENTENCE BUILDER CHECK
        // ══════════════════════════════════════════
        function checkSentenceBuilder() {
            const words = getPrimaryWords();
            const placedIds = exState.sbPlacedIds;
            const result = [];
            let userIdx = 0;
            let expectedPos = 0;
            const handled = new Set();
            const wrongIds = new Set();
            while (expectedPos < words.length) {
                if (wrongIds.has(expectedPos)) {
                    let peekIdx = userIdx;
                    while (
                        peekIdx < placedIds.length &&
                        handled.has(placedIds[peekIdx])
                    )
                        peekIdx++;
                    if (
                        peekIdx < placedIds.length &&
                        placedIds[peekIdx] === expectedPos
                    ) {
                        result.push({
                            id: expectedPos,
                            word: words[expectedPos],
                            status: "correct",
                        });
                        handled.add(expectedPos);
                        userIdx = peekIdx + 1;
                    } else {
                        result.push({
                            id: expectedPos,
                            word: words[expectedPos],
                            status: "displaced",
                        });
                    }
                    expectedPos++;
                    continue;
                }
                while (
                    userIdx < placedIds.length &&
                    handled.has(placedIds[userIdx])
                )
                    userIdx++;
                if (userIdx >= placedIds.length) {
                    result.push({
                        id: expectedPos,
                        word: words[expectedPos],
                        status: "missing",
                    });
                    expectedPos++;
                    continue;
                }
                const userId = placedIds[userIdx];
                if (userId === expectedPos) {
                    result.push({
                        id: expectedPos,
                        word: words[expectedPos],
                        status: "correct",
                    });
                    handled.add(expectedPos);
                    userIdx++;
                    expectedPos++;
                } else {
                    let foundLater = false;
                    for (let j = userIdx + 1; j < placedIds.length; j++) {
                        if (
                            !handled.has(placedIds[j]) &&
                            placedIds[j] === expectedPos
                        ) {
                            foundLater = true;
                            break;
                        }
                    }
                    if (foundLater) {
                        result.push({
                            id: userId,
                            word: words[userId],
                            status: "wrong",
                        });
                        handled.add(userId);
                        wrongIds.add(userId);
                        userIdx++;
                        let peekIdx = userIdx;
                        while (
                            peekIdx < placedIds.length &&
                            handled.has(placedIds[peekIdx])
                        )
                            peekIdx++;
                        if (
                            peekIdx < placedIds.length &&
                            placedIds[peekIdx] === expectedPos
                        ) {
                            result.push({
                                id: expectedPos,
                                word: words[expectedPos],
                                status: "correct",
                            });
                            handled.add(expectedPos);
                            userIdx = peekIdx + 1;
                        } else {
                            result.push({
                                id: expectedPos,
                                word: words[expectedPos],
                                status: "displaced",
                            });
                        }
                    } else {
                        result.push({
                            id: expectedPos,
                            word: words[expectedPos],
                            status: "missing",
                        });
                    }
                    expectedPos++;
                }
            }
            for (let i = userIdx; i < placedIds.length; i++) {
                if (!handled.has(placedIds[i]))
                    result.push({
                        id: placedIds[i],
                        word: words[placedIds[i]],
                        status: "wrong",
                    });
            }
            return result;
        }

        // ══════════════════════════════════════════
        // EXERCISE EVENT DELEGATION
        // ══════════════════════════════════════════
        if (exerciseArea) {
            exerciseArea.addEventListener("click", (e) => {
                // ── Word audio: click on word text plays audio ──
                const clickedEl = e.target;
                // If user clicked the ▲/▼ place icon, skip audio and let action handler below proceed
                if (!clickedEl.closest(".word-tile-place")) {
                    // Check if the clicked element or its parent has word audio
                    const audioEl = clickedEl.closest("[data-word-audio]");
                    if (audioEl) {
                        const wordIdx = parseInt(audioEl.dataset.wordAudio);
                        if (!isNaN(wordIdx) && hasWordAudio(wordIdx)) {
                            // For elements that have no action OR are word-tile with text clicked,
                            // play audio. For listen-reveal, let the toggle still happen below.
                            const isInlineWord = audioEl.classList.contains("listen-order-given-word") || audioEl.classList.contains("listen-fill-word") || audioEl.classList.contains("listen-order-placed") || audioEl.classList.contains("listen-fill-blank");
                            const isResultSpan = audioEl.classList.contains("word-correct") || audioEl.classList.contains("word-displaced") || audioEl.classList.contains("word-wrong");
                            const isBankTile = audioEl.classList.contains("word-tile") && !isInlineWord && !isResultSpan;
                            if (isInlineWord || isResultSpan || isBankTile) {
                                playWordAudio(wordIdx);
                                audioEl.classList.add("word-audio-playing");
                                // For word-tiles in bank, don't proceed to action (audio only)
                                if (isBankTile) {
                                    return;
                                }
                            }
                        }
                    }
                }

                const target = e.target.closest("[data-action]");
                if (!target) return;
                const action = target.dataset.action;

                // Reset exercise (shared across all exercises)
                if (action === "exercise-reset") {
                    exState = {};
                    renderExercise();
                    return;
                }

                // Continue to next incomplete verse (shared across all exercises)
                if (action === "continue-next") {
                    const nextInc = findNextIncomplete(currentIdx);
                    if (nextInc >= 0) {
                        window.location.hash =
                            "#" + learnSteps[nextInc].verseStart;
                        setTimeout(() => playVerse(), 300);
                    }
                    return;
                }

                if (
                    activeExercise === "listen-reveal" &&
                    action === "toggle-all"
                ) {
                    const words = getPrimaryWords();
                    exState.revealedSet =
                        exState.revealedSet.size >= words.length
                            ? new Set()
                            : new Set(words.map((_, i) => i));
                    renderListenReveal();
                    return;
                }
                if (activeExercise === "listen-order") {
                    if (action === "place-word") {
                        const tileEl = target.closest("[data-id]") || target;
                        const id = parseInt(tileEl.dataset.id);
                        const tile = exState.tiles.find((t) => t.id === id);
                        if (tile) {
                            // If the last word was wrong, remove it first
                            const words = getPrimaryWords();
                            const gapIndices = exState.gapIndices;
                            const fw = exState.filledWords;
                            const lastIdx = fw.length - 1;
                            const lastIsWrong =
                                lastIdx >= 0 &&
                                !wordsMatch(
                                    fw[lastIdx].text,
                                    words[gapIndices[lastIdx]],
                                );
                            const base = lastIsWrong ? fw.slice(0, -1) : fw;
                            // Don't add beyond the number of gaps
                            if (base.length >= gapIndices.length) return;
                            exState.filledWords = [
                                ...base,
                                { id: tile.id, text: tile.text },
                            ];
                        }
                        renderListenOrder();
                        return;
                    }
                    if (action === "remove-last") {
                        exState.filledWords = exState.filledWords.slice(0, -1);
                        renderListenOrder();
                        return;
                    }
                }
                if (activeExercise === "listen-fill") {
                    if (action === "fill-bank") {
                        const tileEl = target.closest("[data-word]") || target;
                        const word = tileEl.dataset.word;
                        // If the last word was wrong, remove it first
                        const words = getPrimaryWords();
                        const gapIndices = exState.gapIndices;
                        const fw = exState.filledWords;
                        const lastIdx = fw.length - 1;
                        const lastIsWrong =
                            lastIdx >= 0 &&
                            !wordsMatch(
                                fw[lastIdx].text,
                                words[gapIndices[lastIdx]],
                            );
                        const base = lastIsWrong ? fw.slice(0, -1) : fw;
                        // Don't add beyond the number of gaps
                        if (base.length >= gapIndices.length) return;
                        exState.filledWords = [...base, { text: word }];
                        renderListenFill();
                        return;
                    }
                    if (action === "remove-last") {
                        exState.filledWords = exState.filledWords.slice(0, -1);
                        renderListenFill();
                        return;
                    }
                }
                if (activeExercise === "sentence-builder") {
                    if (action === "sb-place") {
                        const tileEl = target.closest("[data-id]") || target;
                        exState.sbPlacedIds = [
                            ...exState.sbPlacedIds,
                            parseInt(tileEl.dataset.id),
                        ];
                        exState.sbChecked = false;
                        renderSentenceBuilder();
                        return;
                    }
                    if (action === "sb-remove") {
                        const tileEl = target.closest("[data-id]") || target;
                        exState.sbPlacedIds = exState.sbPlacedIds.filter(
                            (pid) => pid !== parseInt(tileEl.dataset.id),
                        );
                        exState.sbChecked = false;
                        renderSentenceBuilder();
                        return;
                    }
                    if (action === "sb-check") {
                        exState.sbResult = checkSentenceBuilder();
                        exState.sbChecked = true;
                        renderSentenceBuilder();
                        return;
                    }
                    if (action === "sb-reset") {
                        exState.sbPlacedIds = [];
                        exState.sbChecked = false;
                        exState.sbResult = null;
                        renderSentenceBuilder();
                        return;
                    }
                    if (action === "sb-hint") {
                        exState.sbHintVisible = !exState.sbHintVisible;
                        renderSentenceBuilder();
                        if (exState.sbHintVisible)
                            setTimeout(() => {
                                exState.sbHintVisible = false;
                                if (activeExercise === "sentence-builder")
                                    renderSentenceBuilder();
                            }, 3000);
                        return;
                    }
                    if (action === "sb-hide-hint") {
                        exState.sbHintVisible = false;
                        renderSentenceBuilder();
                        return;
                    }
                }
            });

            exerciseArea.addEventListener("click", (e) => {
                if (activeExercise !== "listen-reveal") return;
                const wordEl = e.target.closest(".listen-reveal-word");
                if (!wordEl) return;
                const idx = parseInt(wordEl.dataset.idx);
                if (isNaN(idx)) return;
                const wasRevealed = exState.revealedSet.has(idx);
                if (wasRevealed)
                    exState.revealedSet.delete(idx);
                else {
                    exState.revealedSet.add(idx);
                    // Play word audio when revealing
                    if (hasWordAudio(idx)) {
                        playWordAudio(idx);
                        wordEl.classList.add("word-audio-playing");
                    }
                }
                renderListenReveal();
            });
        }

        // ══════════════════════════════════════════
        // AUDIO (uses shared Web Audio store)
        // ══════════════════════════════════════════
        let mtPlaying = false;

        function stopSecondary() {
            const store = getStore();
            if (store) store.stopExerciseAudio();
            mtPlaying = false;
            if (secPlayBtn) secPlayBtn.classList.remove("playing");
        }

        function onVerseEnded() {
            isPlaying = false;
            imageContainer.classList.remove("playing");
            playIcon.innerHTML = "&#9654;";
        }

        function playVerse() {
            if (!VERSE.learnAudioUrl) return;
            const store = getStore();
            if (!store) return;
            stopWordAudio();
            if (mtPlaying) stopSecondary();
            isPlaying = true;
            imageContainer.classList.add("playing");
            playIcon.innerHTML = "&#9208;";
            store.playExerciseVerse(VERSE.learnAudioUrl, VERSE.startTime, VERSE.endTime, onVerseEnded);
        }

        function togglePlay() {
            if (isPlaying) {
                const store = getStore();
                if (store) store.stopExerciseAudio();
                onVerseEnded();
            } else {
                playVerse();
            }
        }

        // ── MT audio ──
        if (secPlayBtn) {
            secPlayBtn.addEventListener("click", () => {
                if (mtPlaying) {
                    stopSecondary();
                    return;
                }
                if (isPlaying) {
                    const store = getStore();
                    if (store) store.stopExerciseAudio();
                    onVerseEnded();
                }
                if (!VERSE.mtAudioUrl) return;
                const store = getStore();
                if (!store) return;
                mtPlaying = true;
                secPlayBtn.classList.add("playing");
                store.playExerciseSecondary(VERSE.mtAudioUrl, VERSE.mtStartTime, VERSE.mtEndTime, () => {
                    stopSecondary();
                });
            });
        }

        // Click image to play
        imageContainer.addEventListener("click", (e) => {
            if (
                e.target.closest(".learn-nav-edge") ||
                e.target.closest(".learn-back-btn")
            )
                return;
            togglePlay();
        });

        // Swipe on image for navigation
        let touchStartX = null;
        imageContainer.addEventListener("touchstart", (e) => {
            touchStartX = e.touches[0].clientX;
        });
        imageContainer.addEventListener("touchend", (e) => {
            if (touchStartX === null) return;
            const diff = touchStartX - e.changedTouches[0].clientX;
            touchStartX = null;
            if (Math.abs(diff) < 80) return;
            var swipeNext = findNextIncomplete(currentIdx);
            var swipePrev = findPrevIncomplete(currentIdx);
            if (diff > 0 && swipeNext >= 0) {
                window.location.hash = "#" + learnSteps[swipeNext].verseStart;
            } else if (diff < 0 && swipePrev >= 0) {
                window.location.hash = "#" + learnSteps[swipePrev].verseStart;
            }
        });

        // Peek
        peekBtn.addEventListener("click", () => {
            if (peekTimer) clearTimeout(peekTimer);
            peekOverlay.classList.add("visible");
            peekTimer = setTimeout(() => {
                peekOverlay.classList.remove("visible");
                peekTimer = null;
            }, 3000);
        });

        // Keyboard
        document.addEventListener("keydown", (e) => {
            var kbNext = findNextIncomplete(currentIdx);
            var kbPrev = findPrevIncomplete(currentIdx);
            if (e.key === "ArrowRight" && kbNext >= 0) {
                window.location.hash = "#" + learnSteps[kbNext].verseStart;
            } else if (e.key === "ArrowLeft" && kbPrev >= 0) {
                window.location.hash = "#" + learnSteps[kbPrev].verseStart;
            } else if (e.key === " ") {
                e.preventDefault();
                togglePlay();
            }
        });

        // ══════════════════════════════════════════
        // NAV ARROWS + HASH NAVIGATION
        // ══════════════════════════════════════════
        navPrev.addEventListener("click", (e) => {
            e.preventDefault();
            const v = parseInt(navPrev.dataset.verse, 10);
            if (!isNaN(v)) {
                history.replaceState(null, "", "#" + v);
                loadVerse(v);
            }
        });
        navNext.addEventListener("click", (e) => {
            e.preventDefault();
            const v = parseInt(navNext.dataset.verse, 10);
            if (!isNaN(v)) {
                history.replaceState(null, "", "#" + v);
                loadVerse(v);
            }
        });
        window.addEventListener("hashchange", () => {
            const verseNum = getVerseFromHash();
            loadVerse(verseNum);
        });

        // ══════════════════════════════════════════
        // INIT
        // ══════════════════════════════════════════
        updateSelectorLabel();

        // Set default hash if none
        if (!window.location.hash || window.location.hash === "#") {
            const firstVerse = learnSteps[0]?.verseStart || 1;
            history.replaceState(null, "", "#" + firstVerse);
        }

        // Load initial verse
        loadVerse(getVerseFromHash());
    </script>
</Layout>
