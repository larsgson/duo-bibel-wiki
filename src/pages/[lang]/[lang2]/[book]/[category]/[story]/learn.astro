---
export const prerender = false;

import Layout from "../../../../../../layouts/Layout.astro";
import storyLocales from "../../../../../../generated/story-locales.json";
import {
    validateParams,
    findTimingData,
    findWordTimingData,
    getFilesetInfo,
    buildVerseEntries,
    getChapterImageData,
    buildChapterData,
    getLangFontScale,
    getLangGapScale,
    getTemplateImageConfig,
    getTemplateThemeCSS,
} from "../../../../../../utils/chapterData";
import { useTranslations } from "../../../../../../i18n";

const { lang, lang2, book, category, story } = Astro.params;

const validated = validateParams({ lang, lang2, book, category, story });
if (!validated) {
    return Astro.redirect(`/${lang}/${lang2}`);
}

const { bookInfo, chapterNum: storyNum, learn, mt } = validated;
const categoryId = category!;
const learnCode = learn.code;
const learnEnglish = learn.english;
const learnVernacular = learn.info.v || learn.info.n || learnCode;
const learnIsRTL = learn.isRTL;
const mtCode = mt.code;
const mtEnglish = mt.english;
const mtVernacular = mt.info.v || mt.info.n || mtCode;
const mtIsRTL = mt.isRTL;
const learnFontScale = getLangFontScale(learnCode);
const mtFontScale = getLangFontScale(mtCode);
const learnGapScale = getLangGapScale(learnCode);

// ── Story data lookup ──
const templateData = (storyLocales as any)[bookInfo.img];
const storyData = templateData?.categories?.[category!]?.stories?.find(
    (s: any) => s.id === story
);

// ── Determine canon for this story's Bible books ──
const OT_BOOKS = new Set([
    "GEN","EXO","LEV","NUM","DEU","JOS","JDG","RUT","1SA","2SA",
    "1KI","2KI","1CH","2CH","EZR","NEH","EST","JOB","PSA","PRO",
    "ECC","SNG","ISA","JER","LAM","EZK","DAN","HOS","JOL","AMO",
    "OBA","JON","MIC","NAH","HAB","ZEP","HAG","ZEC","MAL",
]);
const storyCanon = storyData?.books?.some((b: string) => OT_BOOKS.has(b)) ? "ot" : "nt";

// ── Fileset IDs (both canons) ──
const learnNtFileset = getFilesetInfo(learnCode, bookInfo.img, "nt");
const mtNtFileset = getFilesetInfo(mtCode, bookInfo.img, "nt");
const learnOtFileset = getFilesetInfo(learnCode, bookInfo.img, "ot");
const mtOtFileset = getFilesetInfo(mtCode, bookInfo.img, "ot");
const learnFileset = storyCanon === "ot" ? learnOtFileset : learnNtFileset;

// ── Load timing data for the story's canon ──
let learnTiming = findTimingData(
    learnCode, learnFileset?.audioCategory, learnFileset?.audioDistinctId,
    bookInfo.img, storyCanon,
);
if (!learnTiming) {
    learnTiming = findTimingData(learnCode, undefined, undefined, bookInfo.img, storyCanon);
}
const mtFileset = storyCanon === "ot" ? mtOtFileset : mtNtFileset;
let mtTiming = findTimingData(
    mtCode, mtFileset?.audioCategory, mtFileset?.audioDistinctId,
    bookInfo.img, storyCanon,
);
if (!mtTiming) {
    mtTiming = findTimingData(mtCode, undefined, undefined, bookInfo.img, storyCanon);
}

if (!learnTiming || !learnTiming.timingData[String(storyNum)]) {
    return Astro.redirect(`/${learnCode}/${mtCode}`);
}

const chapterTiming = learnTiming.timingData[String(storyNum)];
const verseEntries = buildVerseEntries(chapterTiming, storyData?.verseRefs);

// ── MT timing ──
let mtChapterTiming: Record<string, number[]> = {};
if (mtTiming) {
    const secChapter = mtTiming.timingData[String(storyNum)];
    if (secChapter) {
        mtChapterTiming = secChapter;
    }
}

// ── Bible chapters from verse refs ──
const bibleChapterSet = new Set<string>();
for (const ve of verseEntries) {
    const m = ve.ref.match(/^([A-Z0-9]{3})(\d+):/);
    if (m) bibleChapterSet.add(`${m[1]}:${m[2]}`);
}
const bibleChapters = [...bibleChapterSet].map(bc => {
    const [bk, ch] = bc.split(":");
    return { book: bk, chapter: parseInt(ch, 10) };
});

// ── Image data & word-level timing ──
const chapterImageData = getChapterImageData(bookInfo.img, storyNum);
const learnWordTiming = learnTiming
    ? findWordTimingData(learnCode, storyNum, learnTiming.category, learnTiming.distinctId, bookInfo.img)
    : null;
const imageConfig = getTemplateImageConfig(bookInfo.img);
const imageBaseUrl = imageConfig.baseUrl;

// ── Data to pass to client ──
const chapterData = buildChapterData({
    bookInfo,
    chapterNum: storyNum,
    verseEntries,
    learnCode,
    mtCode,
    learnFileset: learnNtFileset,
    mtFileset: mtNtFileset,
    learnOtFileset,
    mtOtFileset,
    chapterImageData,
    mtChapterTiming,
    learnWordTiming,
    imageBaseUrl,
    bibleChapters,
    imagePathPattern: imageConfig.pathPattern,
    imageMediumPattern: imageConfig.mediumPattern,
    thumbsResize: imageConfig.thumbsResize,
    verseImages: storyData?.verseImages,
});

const backHref = `/${learnCode}/${mtCode}/${book}/${category}/${story}/`;

const t = useTranslations(mtCode);
const uiLabels = JSON.stringify({
    listenReveal: t("listenReveal"),
    listenOrder: t("listenOrder"),
    listenFill: t("listenFill"),
    sentenceBuilder: t("sentenceBuilder"),
    listen: t("listen"),
    more: t("more"),
    revealAll: t("revealAll"),
    hideAll: t("hideAll"),
    correct: t("correct"),
    incorrect: t("incorrect"),
    orderWords: t("orderWords"),
    check: t("check"),
    fillBlanks: t("fillBlanks"),
    buildSentence: t("buildSentence"),
    completed: t("completed"),
    continue: t("continue"),
    audioOnly: t("audioOnly"),
    textNotAvailable: t("textNotAvailable"),
});
const themeCSS = getTemplateThemeCSS(bookInfo.img);
---

<Layout
    title={`${bookInfo.img} ${storyNum} — ${learnEnglish} + ${mtEnglish}`}
    themeCSS={themeCSS}
    flexMode={true}
    noHeader={true}
>
    <style is:global>
        /* ── Desktop layout ── */
        .exercise-desktop-layout {
            display: flex;
            flex-direction: column;
            max-width: 900px;
            margin: 0 auto;
            min-height: 0;
            flex: 1;
        }

        /* ── Chapter content (scrollable area) ── */
        .chapter-content {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            -webkit-overflow-scrolling: touch;
            display: flex;
            flex-direction: column;
        }

        /* ── Verse view container ── */
        .learn-verse-view {
            display: flex;
            flex-direction: column;
            flex: 1;
            padding: 0.75rem 1rem;
        }
        .learn-verse-main {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            max-width: 600px;
            margin: 0 auto;
            position: relative;
        }

        /* ── Image ── */
        .learn-verse-image-container {
            width: 100%;
            border-radius: 8px;
            overflow: hidden;
            position: relative;
            cursor: pointer;
            border: 3px solid transparent;
            transition: border-color 0.3s;
        }
        .learn-verse-image-container.playing {
            border-color: var(--success);
            animation: image-glow 1.5s ease-in-out infinite;
        }
        @keyframes image-glow {
            0%,
            100% {
                box-shadow: 0 0 4px rgba(76, 175, 80, 0.3);
            }
            50% {
                box-shadow: 0 0 14px rgba(76, 175, 80, 0.5);
            }
        }
        .learn-verse-image {
            width: 100%;
            height: auto;
            display: block;
        }
        .learn-verse-image-play-icon {
            position: absolute;
            bottom: 8px;
            right: 8px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--overlay);
            color: white;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: none;
            transition: background 0.2s;
        }
        .learn-verse-image-container:hover .learn-verse-image-play-icon {
            background: rgba(0, 0, 0, 0.7);
        }
        .learn-verse-image-container.playing .learn-verse-image-play-icon {
            background: rgba(76, 175, 80, 0.7);
        }

        /* ── Back link (inline, left of reference) ── */
        .verse-back-link {
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            text-decoration: none;
            padding: 4px;
            border-radius: 4px;
            transition: color 0.2s;
            flex-shrink: 0;
        }
        .verse-back-link:hover {
            color: var(--accent);
        }

        /* ── Navigation arrows ── */
        .learn-nav-edge {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            border: 1px solid var(--border-strong);
            background: var(--shadow);
            color: var(--text);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            padding: 0;
            width: 20px;
            height: 60px;
            border-radius: 4px;
            z-index: 2;
            text-decoration: none;
        }
        .learn-nav-edge svg {
            width: 16px;
            height: 16px;
            filter: drop-shadow(0 1px 2px var(--overlay));
        }
        .learn-nav-prev {
            left: 0;
            border-left: none;
            border-radius: 0 4px 4px 0;
        }
        .learn-nav-next {
            right: 0;
            border-right: none;
            border-radius: 4px 0 0 4px;
        }
        .learn-nav-edge:hover {
            background: var(--overlay);
            color: var(--text);
        }
        .learn-nav-edge.hidden {
            display: none;
        }

        /* ── Info bar (reference + controls on one line) ── */
        .verse-info-bar {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            width: 100%;
            padding: 0.15rem 0;
        }
        .verse-info-ref {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-secondary);
            font-family: monospace;
            white-space: nowrap;
        }
        .verse-info-counter {
            font-size: 0.7rem;
            color: var(--border-strong);
            white-space: nowrap;
        }
        .verse-info-spacer {
            flex: 1;
        }
        .verse-info-btn {
            background: none;
            border: 1px solid var(--border);
            border-radius: 4px;
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 3px 7px;
            cursor: pointer;
            color: var(--text-secondary);
            font-size: 0.65rem;
            font-family: monospace;
            font-weight: 600;
            text-transform: uppercase;
            transition:
                color 0.2s,
                border-color 0.2s,
                background 0.2s;
            white-space: nowrap;
            flex-shrink: 0;
        }
        .verse-info-btn:hover {
            color: var(--text);
            border-color: var(--text-muted);
        }
        .verse-info-btn svg {
            width: 12px;
            height: 12px;
        }
        .verse-info-btn.peek-btn {
            color: var(--text-muted);
        }
        .verse-info-btn.peek-btn:hover {
            color: var(--text-secondary);
            border-color: var(--text-muted);
        }

        /* ── Text peek overlay ── */
        .text-peek-overlay {
            display: none;
            width: 100%;
            padding: 0.75rem 1rem;
            border-radius: 6px;
            background: var(--bg-surface-hover);
            border-left: 3px solid #6ea8fe;
        }
        .text-peek-overlay.visible {
            display: block;
        }
        .text-peek-content {
            margin: 0;
            font-size: calc(1.125rem * var(--learn-font-scale, 1));
            line-height: 1.6;
            color: var(--text);
        }

        /* ── Secondary language text ── */
        .learn-verse-lang-section {
            padding: 0.75rem 1rem;
            border-radius: 6px;
            overflow-wrap: break-word;
            word-break: break-word;
        }
        .learn-verse-lang-section.secondary {
            background: var(--bg-surface-hover);
            border-left: 3px solid var(--text-muted);
        }
        .lang-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 0.25rem;
        }
        .learn-verse-lang-code {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
        }
        .sec-play-btn {
            background: none;
            border: none;
            padding: 2px;
            margin-right: 0.5rem;
            cursor: pointer;
            color: var(--text-muted);
            transition: color 0.2s;
        }
        .sec-play-btn:hover {
            color: var(--text);
        }
        .sec-play-btn svg {
            width: 16px;
            height: 16px;
        }
        .sec-play-btn.playing {
            color: var(--success);
        }
        .learn-verse-content {
            margin: 0;
            font-size: calc(1.125rem * var(--mt-font-scale, 1));
            line-height: 1.6;
            color: var(--text);
        }

        /* ── No text message ── */
        .no-text-message {
            text-align: center;
            padding: 1rem;
            color: var(--text-secondary);
            font-style: italic;
        }

        /* ══════════════════════════════════════════
           EXERCISE SELECTOR (action sheet trigger)
           ══════════════════════════════════════════ */
        .exercise-selector-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.4rem 0.85rem;
            background: none;
            border: 1px solid var(--border-strong);
            border-radius: 20px;
            color: var(--accent);
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: border-color 0.2s, background 0.2s;
        }
        .exercise-selector-btn:hover {
            border-color: var(--accent);
            background: var(--accent-light);
        }
        .exercise-selector-btn svg {
            width: 16px;
            height: 16px;
        }
        .exercise-selector-chevron {
            font-size: 0.7rem;
            opacity: 0.7;
        }

        /* ── Action sheet overlay ── */
        .action-sheet-overlay {
            position: fixed;
            inset: 0;
            background: var(--overlay);
            z-index: 1100;
            display: flex;
            align-items: flex-end;
            justify-content: center;
        }
        .action-sheet-overlay.hidden { display: none; }
        .action-sheet {
            width: 100%;
            max-width: 500px;
            background: var(--bg-panel);
            border-radius: 16px 16px 0 0;
            padding: 1rem;
            padding-bottom: calc(1rem + env(safe-area-inset-bottom));
        }
        .action-sheet-handle {
            width: 36px;
            height: 4px;
            background: var(--border-strong);
            border-radius: 2px;
            margin: 0 auto 0.75rem;
        }
        .action-sheet-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border: none;
            background: none;
            color: var(--text);
            font-size: 1rem;
            width: 100%;
            cursor: pointer;
            border-radius: 8px;
            text-decoration: none;
            transition: background 0.15s;
        }
        .action-sheet-item:hover { background: var(--accent-light); }
        .action-sheet-item.active { color: var(--accent); background: var(--accent-light); }
        .action-sheet-item svg { width: 22px; height: 22px; flex-shrink: 0; }

        /* ══════════════════════════════════════════
           WORD TILE
           ══════════════════════════════════════════ */
        .word-tile {
            display: inline-block;
            padding: 6px 12px;
            border: 1px solid var(--border-strong);
            border-radius: 6px;
            background: var(--bg-surface-hover);
            color: var(--text);
            font-size: inherit;
            cursor: pointer;
            transition: all 0.15s;
            user-select: none;
        }
        .word-tile:hover {
            background: var(--bg-surface-hover);
            border-color: var(--accent);
        }
        .word-tile:active {
            transform: scale(0.95);
        }
        .word-tile.placed {
            background: var(--accent-light);
            border-color: var(--accent);
        }
        .word-tile.word-correct {
            border: 2px solid var(--success);
            background: var(--bg-surface-hover);
            color: var(--text);
            cursor: default;
        }
        .word-tile.word-wrong {
            background: var(--error);
            border-color: var(--error);
            color: #1a1a1a;
            cursor: default;
        }
        .word-tile.word-displaced {
            background: var(--bg-surface);
            border-color: var(--border-strong);
            color: var(--text-muted);
            cursor: default;
            opacity: 0.7;
        }
        .word-tile.prefilled {
            background: var(--bg-surface);
            border-color: var(--border-strong);
            color: var(--text-secondary);
            cursor: default;
            opacity: 0.7;
        }
        .word-tile.prefilled:hover {
            background: var(--bg-surface);
            border-color: var(--border-strong);
        }
        .word-tile.used {
            opacity: 0.3;
            cursor: default;
        }

        /* ── Word audio ── */
        .has-word-audio {
            cursor: pointer;
        }
        .has-word-audio:not(.word-tile) {
            border-bottom: 1px dotted rgba(91, 155, 213, 0.5);
        }
        .word-audio-playing {
            background: var(--accent-light) !important;
            transition: background 0.15s;
        }
        .word-tile.has-word-audio {
            display: inline-flex;
            align-items: center;
            gap: 0;
            padding: 0;
        }
        .word-tile-text {
            padding: 6px 8px;
            flex: 1;
        }
        .word-tile-place {
            padding: 6px 6px;
            font-size: 0.65rem;
            color: var(--text-secondary);
            border-left: 1px solid var(--border);
            cursor: pointer;
            display: flex;
            align-items: center;
            transition: color 0.15s;
        }
        .word-tile-place:hover {
            color: var(--accent);
        }
        .word-tile.used .word-tile-place {
            display: none;
        }

        /* ══════════════════════════════════════════
           EXERCISE AREA
           ══════════════════════════════════════════ */
        .exercise-area {
            width: 100%;
        }

        /* ── Continue button (after exercise completion) ── */
        .exercise-continue-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 0.5rem;
            padding: 0.5rem 1.5rem;
            background: var(--success);
            color: var(--text-on-accent);
            border: none;
            border-radius: 6px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition:
                background 0.2s,
                transform 0.1s;
        }
        .exercise-continue-btn:hover {
            background: var(--success);
        }
        .exercise-continue-btn:active {
            transform: scale(0.97);
        }
        .exercise-complete-bar {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            width: 100%;
        }
        .exercise-complete-text {
            color: var(--success);
            font-weight: 600;
            font-size: 0.95rem;
            white-space: nowrap;
        }
        .exercise-reset-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 1.1rem;
            cursor: pointer;
            padding: 2px 4px;
            line-height: 1;
            transition: color 0.2s;
        }
        .exercise-reset-btn:hover {
            color: var(--text-secondary);
        }
        .exercise-dismiss-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 1.1rem;
            cursor: pointer;
            padding: 2px 4px;
            margin-left: auto;
            line-height: 1;
            transition: color 0.2s;
        }
        .exercise-dismiss-btn:hover {
            color: var(--text-secondary);
        }

        /* ── Listen & Reveal ── */
        .listen-reveal {
            display: flex;
            flex-direction: column;
            gap: 0;
            width: 100%;
        }
        .listen-reveal-words {
            display: flex;
            flex-wrap: wrap;
            gap: calc(0.35em * var(--learn-gap-scale, 1));
            font-size: calc(1.1rem * var(--learn-font-scale, 1));
            padding: 0.75rem 1rem;
            background: var(--bg-surface-hover);
            border-radius: 6px;
            border-left: 3px solid var(--accent);
            min-height: 60px;
            align-items: center;
        }
        .listen-reveal-word {
            display: inline-block;
            font-size: inherit;
            line-height: 1.6;
            transition: all 0.3s ease;
            cursor: pointer;
            user-select: none;
        }
        .listen-reveal-word.revealed {
            color: var(--text);
        }
        .listen-reveal-word.hidden {
            background: var(--bg-surface-hover);
            border-radius: 3px;
            color: transparent;
            min-width: 30px;
            height: 1.4em;
            border: 1.5px dashed var(--text-muted);
        }
        .listen-reveal-actions {
            display: flex;
            justify-content: flex-end;
            margin-top: 2px;
        }
        .listen-reveal-eye-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--chevron);
            padding: 2px 4px;
            transition: color 0.2s;
        }
        .listen-reveal-eye-btn:hover {
            color: var(--text-muted);
        }

        /* ── Listen & Order (Continue Sentence) ── */
        .listen-order {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            width: 100%;
        }
        .listen-order-instruction {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin: 0;
            text-align: center;
        }
        .listen-order-verse {
            padding: 0.75rem 1rem;
            background: var(--bg-surface-hover);
            border-radius: 6px;
            border-left: 3px solid var(--text-muted);
            font-size: calc(1rem * var(--learn-font-scale, 1));
            line-height: 1.8;
            color: var(--text);
        }
        .listen-order-given-word {
            color: var(--text);
        }
        .listen-order-placed {
            transition: all 0.15s;
        }
        .listen-order-placed.correct {
            color: var(--success);
        }
        .listen-order-placed.incorrect {
            background: var(--error);
            color: #1a1a1a;
            cursor: pointer;
            border-radius: 3px;
            padding: 1px 3px;
        }
        .listen-order-slot {
            color: var(--border-strong);
            font-size: 0.85em;
        }
        .listen-order-bank {
            display: flex;
            flex-wrap: wrap;
            gap: calc(0.35em * var(--learn-gap-scale, 1));
            font-size: calc(0.95rem * var(--learn-font-scale, 1));
            min-height: 40px;
            padding: 0.5rem;
            align-items: center;
        }
        .listen-order-bank.disabled {
            opacity: 0.4;
            pointer-events: none;
        }
        .listen-order-actions {
            display: flex;
            justify-content: center;
            min-height: 40px;
        }
        .listen-order-feedback {
            font-weight: 600;
            font-size: 0.95rem;
            padding: 6px 0;
        }
        .listen-order-feedback.correct {
            color: var(--success);
        }

        /* ── Fill Gap ── */
        .listen-fill-gap {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            width: 100%;
        }
        .listen-fill-instruction {
            font-size: 0.85rem;
