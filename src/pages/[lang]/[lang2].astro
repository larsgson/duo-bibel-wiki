---
export const prerender = false;

import langsData from "../../data/ALL-langs-compact.json";

const { lang, lang2 } = Astro.params;

// Validate learn language exists
const wt = langsData.canons.nt["with-timecode"] as Record<string, unknown>;
const awt = langsData.canons.nt["audio-with-timecode"] as Record<string, unknown>;
if (!wt[lang!] && !awt[lang!]) {
    return Astro.redirect("/");
}

// Validate mother tongue exists (in any non-failed category)
let found = false;
for (const canon of ["nt", "ot"] as const) {
    const canonData = (langsData.canons as any)[canon];
    if (!canonData) continue;
    for (const cat of Object.keys(canonData)) {
        if (cat === "failed" || cat === "audio-only") continue;
        if (canonData[cat][lang2!]) {
            found = true;
            break;
        }
    }
    if (found) break;
}
if (!found) {
    return Astro.redirect("/");
}
---

<html>
<head><meta charset="utf-8" /><title>Redirecting…</title></head>
<body>
<script is:inline define:vars={{ lang, lang2 }}>
    localStorage.setItem("selectedLang", lang);
    localStorage.setItem("selectedMT", lang2);
    window.location.replace("/");
</script>
</body>
</html>
